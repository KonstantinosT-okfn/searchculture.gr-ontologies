    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to cargo-hauling land vehicles comprised of a driver's cab but no body, designed for towing truck trailers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
