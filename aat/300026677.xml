    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A semantic network of unique concepts, including relationships between synonyms, broader and narrower contexts, and other related concepts. Thesauri may be monolingual or multilingual. Thesauri may have the following three relationships between terms: equivalence (synonyms), hierarchical (whole/part), and associative (various types of other relationships).</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
