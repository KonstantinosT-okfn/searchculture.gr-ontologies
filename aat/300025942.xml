    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Upper class within the aristocracy, whose titles, property, and privileges are maintained and passed on by heredity. For individual members of the nobility use "nobles (aristocrats)."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
