    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Printed documents containing the names, descriptions, and wage information of every member of a ship's company, including the master's name and the ship's name, destination, and tonnage.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
