    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Projectile points or blades with a stem-like extension of the base to allow hafting or gripping. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
