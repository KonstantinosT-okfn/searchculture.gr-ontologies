            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Uitvoerig beschilderde platte poppen, meestal van leer, die oorspronkelijk werden ontwikkeld op Java en werden gebruikt om tijdens uitvoeringen schaduwen te werpen op witte schermen</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
