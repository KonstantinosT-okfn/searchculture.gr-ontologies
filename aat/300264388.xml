          <Note_Source>
            <Source>
              <Source_ID>2000051034/TAA database (2000-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Verwijst naar tweedimensionale weergaven van personen, dieren, objecten, plaatsen of verschijnselen. Doorgaans wordt ermee verwezen naar dergelijke weergaven met betrekking tot tekeningen, foto's, films of digitale formaten.</Note_Text>
        <Note_Language>Dutch</Note_Language>
