    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>May refer generally to any person who visits a place that they do not normally inhabit. Specifically, an official that visits a place or operation at intervals for the purpose of inspection or supervision.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
