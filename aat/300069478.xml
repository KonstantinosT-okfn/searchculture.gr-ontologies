            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000079228/Grove Art Online (2008-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Úsese generalmente para arte producido usando computadores en algúna etapa del proceso.</Note_Text>
        <Note_Language>Spanish</Note_Language>
