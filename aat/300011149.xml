    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A velvety-black variety of cryptocrystalline quartz, siliceous shale, or similar substance used by jewelers for testing the purity of precious metal, especially gold, by the streak left on the stone when rubbed with the metal.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
