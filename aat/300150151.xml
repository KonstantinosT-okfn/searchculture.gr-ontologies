            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000114707/Oxford English Dictionary Online (2002-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Lugar en el que se almacenan archivos, manuscritos, libros u otros documentos.</Note_Text>
        <Note_Language>Spanish</Note_Language>
