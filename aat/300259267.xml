    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Use to refer to works by the ethnic group of the same name living in central Nigeria near the confluence of the Niger and Benue Rivers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
