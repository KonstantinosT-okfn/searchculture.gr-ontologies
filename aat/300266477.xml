    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Unit of measurement for computer file storage equal to approximately one trillion bytes. Specifically, 1,099,511,627,776 bytes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
