    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Use generally for the production and use of microforms.  For the process of producing microforms, use "microphotography."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
