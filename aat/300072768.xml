    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The increase in amplitude of oscillation of a mechanical system exposed to the periodic force of a naturally occurring or artificially induced earthquake.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
