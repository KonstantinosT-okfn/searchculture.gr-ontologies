    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A diamond shaped figure with hooks projecting from the outermost diamond; a rectangular figure with lateral projecting hooks; or a triangular figure with a projecting hook serving as the tail.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
          <Note_Contributor>
