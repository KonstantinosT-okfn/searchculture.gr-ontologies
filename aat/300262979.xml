    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>African monkey figures of the Baule people, characterized by open hands or small offering cups for sacrificial offerings.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
