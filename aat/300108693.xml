    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Toilets that are not connected to a sewage system, and which have a compartment in which waste is treated with a chemical solution for temporary storage, and for deodorization. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
