    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Named for French mathematician Pierre Bézier. Use for curves rendered mathematically from cubic equations generated from a series of control points. Bezier curves are used in computer programs to create curved lines for graphics and complex paths for 3-D modeling. A Bezier curve is a form of b-spline curve.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
