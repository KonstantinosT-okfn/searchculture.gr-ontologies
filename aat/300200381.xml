    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Instruments for measuring altitudes, usually consisting of a graduated arc of 90 degrees, a pair of sights, and a plumb bob.</Note_Text>
        <Note_Language>English</Note_Language>
