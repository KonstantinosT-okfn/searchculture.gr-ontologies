    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Limited access highways located within a park or parklike setting and intended for only passenger cars and noncommercial traffic.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
