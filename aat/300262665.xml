    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Term used to describe works produced by the African ethnic group of the same name living in Cameroon, Republic of the Congo, and Central African Republic.</Note_Text>
        <Note_Language>English</Note_Language>
