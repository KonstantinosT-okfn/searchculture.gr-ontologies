    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Armor pieces protecting the throat and lower part of the face, worn either independently or attached to the helmet skull by pivoting rivets.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
