    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Persons who use movement, gesture, facial expressions, speaking, and intonation to create a fictional character for the stage, motion pictures, or television.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
