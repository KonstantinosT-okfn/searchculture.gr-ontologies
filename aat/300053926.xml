    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Method of prestressing concrete in which the tendons, such as steel cables or rods, are tensioned after the concrete has hardened.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
