    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Specifically, those who play the double bass.Also refers generally for those who play bass instruments of any kind.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
