    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Objects designed to attract fish for capture.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
