    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Calibrated devices for measuring the flow of liquids in open conduits by observing differences in the heads on opposite sides of a partial obstruction.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
