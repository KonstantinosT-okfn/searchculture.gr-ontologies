    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Devices permanently secured to the hasp on a door which causes the hasp to be locked as soon as the door is closed; often used in prisons.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
