    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Natural depressions or courses in the earth's surface that are filled with water, including seas, lakes, and rivers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
