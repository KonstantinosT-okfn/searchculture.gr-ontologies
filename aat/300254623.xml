    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Caps with a spherical crown and side and rear flaps, often of fur; worn from the 17th century onward, originally by Spanish hunters.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
