    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The quality of having a surface free from projections, irregularities, or inequalities, presenting no roughness or unevenness to the touch or sight.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
