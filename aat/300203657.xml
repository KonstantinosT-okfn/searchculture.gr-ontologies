    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Metal tubes fitted to helmets and shaffrons, typically covered by a small decorative plate, rondel, or shield, to support a plume.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
