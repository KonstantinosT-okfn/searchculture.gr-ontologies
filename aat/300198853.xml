    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ancient Greek storage vessels for wine, water, or oil, similar to amphorae but with a pointed bottom and characterized by two side handles.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
