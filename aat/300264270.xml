            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Overkledij zonder snit uit Madagaskar die zowel door mannen als vrouwen rond de schouders en soms rond de bovenste helft van de romp wordt geslagen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
