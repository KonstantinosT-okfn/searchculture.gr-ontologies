    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lightweight bedspreads composed of small fabric circles, slightly smaller than yo-yos, with turned edges gathered toward the center.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
