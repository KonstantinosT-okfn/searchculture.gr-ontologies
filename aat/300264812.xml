    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Describes the artwork created by the Asmat people of Sepik region.  Elaborate sculptures are their primary art form. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
