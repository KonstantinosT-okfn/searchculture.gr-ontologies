    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Arabic script used primarily in modern day Iran and Afghanistan. Shikasteh, translating roughly as 'broken' or 'broken form', is a dense script with a lack of diacritical marks.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
