    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Sculptural works that incorporate sound; used especially in reference to sculptural instruments for performance, such as those created by François and Bernard Baschet, Robert Rutman, Charles Mattox, and Harry Bertoia, among others.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
