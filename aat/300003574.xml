    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Moldings or groups of moldings used to cover the joint between two surfaces on different levels and projecting beyond the surface of both.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
