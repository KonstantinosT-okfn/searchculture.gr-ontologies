    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Stick-like implements intended to apply cosmetics or sticks composed of a cosmetic. Best known as works from ancient Egypt, Asia, and elsewhere.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000047822/MFA Conservation and Art Material Encyclopedia Online: CAMEO (2005-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Stokjes waarmee men cosmetica aanbracht of die zelf een cosmetisch product bevatten. Veel gebruikt in onder meer het oude Egypte en Azië.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
