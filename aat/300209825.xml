    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Short woolen mantles fastened on the right shoulder, worn by men of ancient Greece.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
