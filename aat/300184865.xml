    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small objects carved in wood, ivory, horn, or sometimes wrought in metal; used as toggles for Japanese kimonos or pouches.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
