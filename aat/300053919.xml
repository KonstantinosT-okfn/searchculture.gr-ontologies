    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The application of slip to a piece of pottery with a syringelike device so as to create slightly raised linear decoration.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
