    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Term used to describe works produced by members of the pan-ethnic group of people speaking the language of the same name, living in central, southern, and eastern Africa.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
