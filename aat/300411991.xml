    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The oral manifestation of languages; language produced by articulate sounds, as opposed to a written language. Many languages have no written form and so are only spoken.</Note_Text>
        <Note_Language>English</Note_Language>
