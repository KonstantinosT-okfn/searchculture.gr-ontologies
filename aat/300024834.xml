    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Equipment used for cleaning or removing surfaces by a controlled stream of pressure-ejected material consisting of sand or manufactured grit.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
