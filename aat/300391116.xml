    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Bags used to collect money, often made of cloth or leather, usually mounted on a support having handles; a primary example is in collecting money from members of the congregation during religious services.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
