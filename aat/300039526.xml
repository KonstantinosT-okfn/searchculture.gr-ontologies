    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Fall-front desks having a writing surface that, when closed, folds upward and inward, forming an angle with the carcass.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
