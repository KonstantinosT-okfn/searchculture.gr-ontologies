    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Greeting cards that are sent or given as expressions of goodwill at Christmastime. The first Christmas cards were made in the 1840s in England. The tradition is followed in all English-speaking countries and the practice is growing in many others.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
