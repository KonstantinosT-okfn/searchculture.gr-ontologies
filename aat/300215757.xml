    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Hand-held electrical appliances having one or more beaters and used in mixing, beating, or creaming food.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
