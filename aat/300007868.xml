    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Bridges in which the roadway is suspended from cables, ropes, or chains attached to natural or constructed supports. The term applies both to primitive and massively engineered structures that share this basic principle.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
