    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>In general, women of distinction without precise designation of rank. Women considered by the society to be of good birth or breeding.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
