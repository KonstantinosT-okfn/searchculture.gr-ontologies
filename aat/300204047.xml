            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Mijnen die op of net onder het maaiveld geplaatst zijn.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
