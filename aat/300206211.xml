    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A script of ancient Egypt consisting of abridged forms of hieroglyphics, used by the priests in their records.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
