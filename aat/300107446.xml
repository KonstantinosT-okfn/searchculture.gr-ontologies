    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to the style and cultures that developed on the Italian peninsula in places where Etruscans came into contact with Greek culture through Greek colonists and their art.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
