    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Simple geometric forms composed of Vs used singly, in a vertical series, or in a string to form a zigzag.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000024841/Lewis and Darley, Dictionary of Ornament (1986)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Formas geométricas simples compuestas que son usadas individualmente, en una serie vertical o en un cordón para formar un zigzag.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
