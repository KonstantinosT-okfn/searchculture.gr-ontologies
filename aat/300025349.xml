    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Generally, craftspeople or industrial workers engaged in any or all of the processes involved in textile manufacture.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
