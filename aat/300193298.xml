      <Descriptive_Note>
        <Note_Text>Úsese para obras de las artes visuales que son diseñadas para lugares específicos, especialmente aquellas que exploran o incorporan aspectos de esos lugares.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
