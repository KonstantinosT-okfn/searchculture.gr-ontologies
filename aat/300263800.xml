        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>pyroclastic rock [300011253], extrusive rock [300011246], igneous rock by origin [300011243], igneous rock [300011178], rock (inorganic material) [300011692], inorganic material [300010360], materials by composition [300212963], materials (substances) [300010358], Materials (hierarchy name) [300010357], Materials Facet [300264091]</Parent_String>
