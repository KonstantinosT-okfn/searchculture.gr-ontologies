        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Sierpottenbakkerswerk vervaardigd door kunstenaars en ambachtslieden die de nadruk leggen op het artistieke aspect van hun werk; van een type dat nauw verwant is aan de Arts &amp; Crafts Movement.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
