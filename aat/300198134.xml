    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Quilts composed of three-dimensional puffs, small silk squares slightly gathered and stuffed with batting, pieced together.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
