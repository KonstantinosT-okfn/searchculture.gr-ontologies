    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Style and culture of the inhabitants of ancient Carthage and its colonies in the western Mediterranean, Adriatic coast, and Spain during the first millennium BCE.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
