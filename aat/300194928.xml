    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Baskets of varying form used to transport goods on animals or humans; includes those with one flattened side made to conform to the contour of the body.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
