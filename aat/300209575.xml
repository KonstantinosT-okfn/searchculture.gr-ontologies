    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Rectangular, sloping slabs to be placed under one end of a platter, so causing gravy to flow to the opposite end.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
