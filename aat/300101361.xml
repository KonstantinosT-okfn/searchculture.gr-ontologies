        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>De zijkanten of randen langs een weg, onverschillig aan welke kant, met name dat gedeelte waar voertuigen kunnen parkeren in noodsituaties.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
