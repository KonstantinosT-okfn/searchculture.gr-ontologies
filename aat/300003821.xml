    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Pulpits in mosques, having a small stand for the speaker, parapet, canopy, narrow stairs, and usually a gate at the foot of the stairs.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000077471/Sturgis, Dictionary of Architecture and Building (1901)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Kansels in moskeeën met een klein platform voor de spreker, een balustrade, een baldakijn, een smalle trap en meestal met een poort aan de voet van de trap.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
