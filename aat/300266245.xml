    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The color of fabric stained by mauve dye, generally light shades of purple ranging between lilac and violet, but may also refer to deep purple tones.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
