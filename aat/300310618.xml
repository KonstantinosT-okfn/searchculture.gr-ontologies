    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Members of a family containing around 3000 species of small or medium-sized moths that hold their wings over the body when at rest.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
