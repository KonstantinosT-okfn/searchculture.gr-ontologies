    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A sandstone containing 10 to 25% feldspar that is intermediate between a quartz sandstone and an arkosic sandstone.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
