            <Source>
              <Source_ID>2000051034/TAA database (2000-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>De verdikking van een ondergrondse stengel, wortel of wortelstok, waarin voedsel wordt opgeslagen, met  knopjes waaruit nieuwe planten kunnen groeien.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
