    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Describes works created by the African people of the same name, a subgroup of the Igbo living in an area centered on the town of Arochukwe in southeastern Nigeria.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
