    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>In general, an orderly classification for a defined domain. More specifically, a classificatory nomenclatures of real objects, organisms, or phenomena, especially for living and extinct organisms.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
