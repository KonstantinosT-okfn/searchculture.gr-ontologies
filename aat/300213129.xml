            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Een transparante witte kristallijnen verbinding met de formule KNO3. Het wordt gebruikt bij de productie van explosieven, pyrotechniek, lucifers, drijfgas voor raketten en kunstmest.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
