    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Wood, aluminum, or magnesium boards mounted on poles; used to spread and smooth freshly placed, horizontal concrete surfaces.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
