    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Official lists of recorded deaths, including details considered sufficiently important to be formally noted, and maintained in a regular manner for a community; typically including the names of the deceased, dates of death, living relatives, and often location and cause of death.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
