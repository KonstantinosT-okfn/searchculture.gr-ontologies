    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A spring whose water is much warmer than the surrounding air because it has been heated by geothermal energy.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000132/Suzzallo-UW</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
