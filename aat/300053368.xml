    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Application of paint in thick, opaque masses, usually with a well-loaded brush or a palette knife.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
