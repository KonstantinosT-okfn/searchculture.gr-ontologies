    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tibetan scrolls or fabric temple banners bearing religious images, usually painted but sometimes embroidered or appliquéd; they are hung in temples or carried in processions.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
