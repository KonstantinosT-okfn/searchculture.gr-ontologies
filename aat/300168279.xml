    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Printers that create each character from an array of dots that are usually formed by transferring ink by mechanical impact.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
