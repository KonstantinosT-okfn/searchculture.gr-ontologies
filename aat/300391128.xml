          <Note_Source>
            <Source>
              <Source_ID>2000110648/Portuguese Translation Intern Project (2020-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Medaglie aventi un soggetto religioso o devozionale, presenti in contesti cristiani e religiosi, spesso dotate di un anello per consentire di indossare la medaglia.</Note_Text>
        <Note_Language>Italian</Note_Language>
