    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Thin flat clappers of bone, ivory, or hardwood played in pairs, usually a pair in each hand.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
