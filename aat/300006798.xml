    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small structures, usually roofed and open-sided, located in gardens or parks from which one may gaze out over the surrounding grounds.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
