    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Funerary figures, similar to the cloth-covered funerary figures of the Bwende, known as niombo, but smaller in size and not as widely used.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
