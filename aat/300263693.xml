    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Pottery made by slaves, frequently found at plantation sites in South Carolina, Virginia, and several Caribbean Islands.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
