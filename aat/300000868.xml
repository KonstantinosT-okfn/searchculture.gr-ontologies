    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The high-density cores of cities or towns, where activities are principally retail, commercial, service, and often governmental.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
