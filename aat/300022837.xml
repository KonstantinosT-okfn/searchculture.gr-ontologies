            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000099099/Van Dale groot woordenboek (1994)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Motorsäge, die zum Einkerben ungehärteten Betons verwendet wird, um Rissbildung vorzubeugen, oder beim Schneiden harter Betonplatten.</Note_Text>
        <Note_Language>German</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000232/IfM-SMB-PK</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
