    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Styles and cultures from a wide region of Africa that straddles the Equator and is drained largely by the Congo River system.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
