    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>In refrigeration systems, the heat exchangers that remove heat from the refrigerant and transform a hot gas under pressure into a cool liquid.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
