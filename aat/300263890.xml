    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to plans for the brick, concrete, or stone foundations, walls, and piers of a building.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
