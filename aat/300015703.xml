        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>ancient East African [300015702], Ancient African [300015690], African (general, continental cultures) [300015647], styles, periods, and cultures by region [300111079], Styles and Periods (hierarchy name) [300015646], Styles and Periods Facet [300264088]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
