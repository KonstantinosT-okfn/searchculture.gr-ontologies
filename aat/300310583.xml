        <Parent_String>Canis (genus) [300265714], Canidae (family) [300265713], Carnivora (order) [300310328], Mammalia (class) [300265707], Vertebrata (subphylum) [300265720], Chordata (phylum) [300266513], Animalia (kingdom) [300249395], Eukaryota (domain) [300265677], living organisms (entities) [300390503], Living Organisms (hierarchy name) [300265673], Agents Facet [300264089]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
      </Preferred_Parent>
    </Parent_Relationships>
    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>General term for members of four species of medium-sized canids found in Africa, Asia southeastern Europe, filling an ecological niche of predators of small to medium-sized animals, scavengers, and omnivores, similar to the coyote in North America.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
