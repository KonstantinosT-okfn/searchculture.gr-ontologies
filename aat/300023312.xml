    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Machines for welding that use a power supply to create an electric arc between an electrode and the base material, in order to melt metals at the welding point.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000077271/Rao, Manufacturing Technology (2001)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Maschine zum Schweißen, die eine Stromversorgung verwendet, um einen Lichtbogen zwischen einer Elektrode und dem Ausgangsmaterial zu erzeugen, um Metall an der Schweißstelle zu schmelzen.</Note_Text>
        <Note_Language>German</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000232/IfM-SMB-PK</Contributor_id>
          </Note_Contributor>
