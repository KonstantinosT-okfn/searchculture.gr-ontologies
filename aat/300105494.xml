    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Cable structures in which a field of crossed cables, of different and often reverse curvatures, make up the primary roof surface.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
