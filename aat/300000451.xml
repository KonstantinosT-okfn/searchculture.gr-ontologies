    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Use only for military weapons testing; for small arms target ranges, use "shooting ranges" or a more specific term.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
