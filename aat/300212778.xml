    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ensembles of voices and/or instruments in English music from about 1570 to 1720; also, present-day ensembles of like nature which play music of that period.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
