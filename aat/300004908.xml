    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Distinguished from "stables" by their barnlike appearance and their use as housing primarily for farm stock, feed, and associated maintenance equipment.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
