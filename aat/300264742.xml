    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Buildings, part of a building, or complex in which training or education takes place. It is not necessarily a formal school.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
