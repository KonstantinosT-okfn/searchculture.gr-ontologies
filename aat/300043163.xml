    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small spoons intended primarily for serving prepared (wet) mustard from mustard pots; usually have an elongated bowl and a long, thin handle.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
