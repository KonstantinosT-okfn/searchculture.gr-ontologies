    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Style and culture of the African people of the same name living on the slopes of  Mount Kilimanjaro in northeast Tanzania.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
