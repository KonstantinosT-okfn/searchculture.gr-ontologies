    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Science dealing with the earth and its life, especially the description of land, sea, air, and the distribution of plant and animal life, including human beings, their activities and territorial organizations.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
