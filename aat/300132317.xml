    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Denotes small rounded indentations in a coastline, smaller than bays and generally characterized by a narrow entrance.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
