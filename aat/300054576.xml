    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The profession concerned with the application of knowledge and those principles, theories, techniques, and technologies which contribute to the establishment, preservation, organization and utilization of libraries and library materials.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
