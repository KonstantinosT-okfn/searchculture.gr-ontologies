    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Bolts applied at the bottom of a door and arranged for foot operation; held up by a spring when door is unbolted.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
