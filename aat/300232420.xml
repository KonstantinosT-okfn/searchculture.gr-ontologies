    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Political units, such as nations, that exercise and are recognized internationally as possessing sovereignty.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
