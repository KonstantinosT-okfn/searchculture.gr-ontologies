    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Irons used for crimping, plaiting, or fluting the edges of lace, linen, or a trimming or textile of any kind.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
