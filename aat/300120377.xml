    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Public or private ancient Roman baths or bath buildings of ordinary size. For the great ancient Roman baths, use "thermae."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
