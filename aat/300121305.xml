    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Reproductions of whole objects when the intention is to deceive; includes sculptures cast without the artist's permission.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
