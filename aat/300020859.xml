            <Source>
              <Source_ID>2000051034/TAA database (2000-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Term van de 19e eeuwse kunsthistorici om de hoge gotiek aan te duiden. VWB.</Note_Text>
