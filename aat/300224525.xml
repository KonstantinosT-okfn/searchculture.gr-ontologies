            <Source>
              <Source_ID>2000051034/TAA database (2000-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Borstbeschermers van wol, flannel of bont die ook dienst deden als buste-verbeteraars. Werden gebruikt aan het eind van de 18e, begin 19e eeuw.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
