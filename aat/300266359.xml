    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Sculpted works comprising groups of figures, similar in scale and size to crèches, that depict the Crucifixion and other events of the Christian Holy Week.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
