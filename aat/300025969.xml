        <Parent_String>companies [300160084], business enterprises by form [300256409], businesses (business enterprises) [300025966], organizations (groups) [300025948], Organizations (hierarchy name) [300234770], Agents Facet [300264089]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
