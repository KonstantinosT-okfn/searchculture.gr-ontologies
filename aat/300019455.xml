    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Designates work of Migration period peoples, characterized by inlays of multicolored stones, usually in gold.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
