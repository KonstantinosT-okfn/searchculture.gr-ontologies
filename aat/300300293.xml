            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Supporto con ripiano inclinato per il libro liturgico. Realizzato in legno o in metallo, puù essere pieghevole e viene posto sopra la mensa dell'altare.</Note_Text>
        <Note_Language>Italian</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
