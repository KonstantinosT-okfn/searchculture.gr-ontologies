    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Signs that confirm destinations; for smaller, less public identifying notices, use "labels (identifying artifacts)."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
