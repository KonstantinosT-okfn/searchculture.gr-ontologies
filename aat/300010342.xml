    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Use in the sense of interrupted by design. For the sense of damaged, see 'broken' (ALT of "breaking").</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
