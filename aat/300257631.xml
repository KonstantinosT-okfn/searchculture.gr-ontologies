    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Designs, often arabesques, used to ornament the corners of the covers of books generally for the purpose of matching a centerpiece or other form of decoration.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
