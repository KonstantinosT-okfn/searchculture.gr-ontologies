        <Parent_String>Malpighiales (order) [300374936], Rosanae (superorder) [300419947], Magnoliopsida (class) [300375593], Angiospermae (division) [300265706], Plantae (kingdom) [300132360], Eukaryota (domain) [300265677], living organisms (entities) [300390503], Living Organisms (hierarchy name) [300265673], Agents Facet [300264089]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
      </Preferred_Parent>
    </Parent_Relationships>
    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Family containing 55 genera and more than 1,000 species of deciduous or evergreen shrubs and trees. The family is most common in the tropics and grows worldwide, except for New Zealand, and only a few species are found in Australia. Classification is disputed.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
