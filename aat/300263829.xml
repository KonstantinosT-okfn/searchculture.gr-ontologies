    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Having the form or outline of a half of an ellipse that is bisected by one of its diameters.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
