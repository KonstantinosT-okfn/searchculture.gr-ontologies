    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Reeds in the form of a stretched band or ribbon, stretched taut between two points, against which an air stream is directed.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
