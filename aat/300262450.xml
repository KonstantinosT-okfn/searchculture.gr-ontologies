    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Painting of the body, either in connection with ceremonies, festivals, or other special events, or for reasons of personal decoration.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
