    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Paintings executed in oil paint that were intended as preparatory studies of a more finished, usually larger, painting.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
