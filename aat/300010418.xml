    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>An artificial cement with hydraulic properties that is made by grinding together granulated blast-furnace slag and hydrated lime.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
