    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Describes an enclosed empty space in architecture, sculpture, or painting which makes an essential contribution to the composition.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
