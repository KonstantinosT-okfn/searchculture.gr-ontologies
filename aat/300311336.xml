    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A pattern consisting of five elements arranged at each of the four corners of a square or rectangle, and one in the center. Often used in series as a motif in a border or field in textiles.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000132/Suzzallo-UW</Contributor_id>
          </Note_Contributor>
