    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Use to describe Ethiopian art and architecture associated with the Gondar dynasty, which lasted from the mid-16th to mid-18th century.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
