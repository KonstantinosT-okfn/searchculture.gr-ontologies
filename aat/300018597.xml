    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Style of Japanese porcelain produced in the Arita district of Hizen.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
