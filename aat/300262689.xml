    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Roman facing technique in which irregularly shaped small blocks or stones are applied over a concrete wall.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
