          <Note_Source>
            <Source>
              <Source_ID>2000109721/GRI, FloCo terminology (2019-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
    </Descriptive_Notes>
