            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Kunstnijverheidsstijl in zwang ten tijde van het regentschap in Frankrijk (1715-1723).</Note_Text>
        <Note_Language>Dutch</Note_Language>
