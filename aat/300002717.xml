    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Low walls, placed at the edge of platforms, balconies, terraces, bridges, quays, or roofs, or surmounting the cornices of a building; examples include the low walls forming the uppermost part of defensive walls or ramparts.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
