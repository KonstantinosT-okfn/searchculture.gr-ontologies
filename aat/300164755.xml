    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Gardens or landscapes designed for low water maintenance by plant selection, planting techniques, and irrigation systems tolerant of low water input.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
