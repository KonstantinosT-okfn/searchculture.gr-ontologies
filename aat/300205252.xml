    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Upright grand pianos in the form of a truncated pyramid, developed in the 18th century and remaining popular until the early 19th.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
