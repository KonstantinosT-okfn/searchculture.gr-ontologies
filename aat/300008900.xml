    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Areas of virtually stagnant water that are joined to a stream but relatively unaffected by its current.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
