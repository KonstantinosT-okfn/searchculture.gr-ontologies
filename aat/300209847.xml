    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Woolen garments worn by women of ancient Greece; often open on one side, and fastened on both shoulders.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
