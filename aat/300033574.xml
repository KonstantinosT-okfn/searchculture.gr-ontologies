    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Screws that clamp a movable part when it is required to be fixed, or otherwise form a stop, which check the motion or thrust of a mechanism or determine the position to which a part may be moved.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
