    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Round buildings, especially those that are round both outside and inside and covered by domes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
