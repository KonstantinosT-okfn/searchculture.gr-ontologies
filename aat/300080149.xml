    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Handles in the form of relatively small masses, usually rounded, and projecting from a surface or extremity.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
