    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Warp supplementary to the main warp, which creates a pattern or texture in floats above the ground of the textile.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
