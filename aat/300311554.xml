    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Nonstandardized name for a yellow earth pigment, typically having a warm yellow color, generally from a material produced in Italy and used in ancient Rome.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
