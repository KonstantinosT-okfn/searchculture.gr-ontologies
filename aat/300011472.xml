    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A dark, gray brown marble, closely packed with fossil shells, which when polished gives a brilliant gleam.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
