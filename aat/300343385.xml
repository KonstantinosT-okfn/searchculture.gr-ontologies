    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Libraries responsible for films and other moving image materials, including stock footage, films, film clips and/or videotapes; some may include microfilm as well. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
