    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Technique for evaluating basic structural properties of paper using wet and dry paper strips over a range of short spans from 0 to 1 mm.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
