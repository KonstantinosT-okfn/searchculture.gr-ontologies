    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>General-use nails each having a head and a diamond-shaped point that are used where appearance is not important, as in framing.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
