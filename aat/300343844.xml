    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Deep regret, guilt, or sorrow for having done something morally wrong or otherwise considered incorrect.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
