    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Four opposing sets of rams horns, usually with a diamond in the middle.  The four sets often appear within a gül.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000132/Suzzallo-UW</Contributor_id>
          </Note_Contributor>
          <Note_Contributor>
