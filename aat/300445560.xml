    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>General category of labret that hangs from the lower lip. Worn by young Nahua men and warriors in postclassic central Mexico. Made primarily from stone, but also in metal and with a wide variety of shapes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000320/GRI-FloCo</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
