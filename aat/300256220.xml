    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to the dissipation of energy in motion of any type, especially oscillatory motion, and the consequent reduction or decay of the motion.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
