            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Vaak kostbaar gedecoreerde doedelzakken, uit Frankrijk, 17de, vroege 18de eeuw.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
