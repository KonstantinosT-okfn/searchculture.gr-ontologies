    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Load on a column or pile which is nonsymmetric with respect to the central axis, therefore producing a bending moment.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
