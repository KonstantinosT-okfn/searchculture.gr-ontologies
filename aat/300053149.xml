            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000026701/Mayer, Dictionary of Art Terms and Techniques (1969)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Acto de dar forma a la madera, piedra u otro material por corte o incisión.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
