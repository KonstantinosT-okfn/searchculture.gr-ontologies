    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lamps, often set in rotating Fresnel lenses, in lighthouses. Early lighthouse lamps were powered by incandescent gas burners.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
