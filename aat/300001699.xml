    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Uppermost members of the capitals of columns; often plain square slabs, but sometimes molded or otherwise enriched.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
