    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Describes works created by the inhabitants of the Tuvalu Islands. The artwork of the Tuvalu primarily consists of tattoo and canoe design. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
