    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to screens surrounding or placed in front of confessionals in order to shield penitents from public view.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
