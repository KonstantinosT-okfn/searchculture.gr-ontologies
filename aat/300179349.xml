    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Nineteenth-century architectural style developed in Monterey, California, as a blend between local adobe structures and Yankee woodwork.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
