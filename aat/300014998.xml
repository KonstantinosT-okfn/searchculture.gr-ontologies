    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A heat-bodied linseed oil that is the vehicle in lithographic ink and usually in other printing ink.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
