    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Pairs of tall casement windows closing against each other with no frame between them, allowing access to the outside or to another room. For single tall window-like doors, use "French doors."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
