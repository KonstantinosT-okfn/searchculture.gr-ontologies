    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Bands, sashes, or belts, usually richly ornamented, worn diagonally from shoulder to hip to support a dagger, bugle, sword, or drum.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
