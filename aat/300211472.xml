    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Adhesive bindings produced in the mid-19th century using a rubber solution to glue the leaves together. They ceased to be made years later when it was discovered that  rubber turns brittle over time.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000099620/Legacy AAT data</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Klevende bindingen die geproduceerd zijn in het midden van de 19e eeuw, waarbij een rubber oplossing is gebruikt.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
