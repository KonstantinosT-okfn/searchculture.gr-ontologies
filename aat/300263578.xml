    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Trade name for a book cloth made by the Winterbottom Book Cloth Company of England, made of linen and finished with a grain pattern resembling that of leather, most often straight-grain morocco.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
