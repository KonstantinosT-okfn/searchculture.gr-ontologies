    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Grating or openwork barriers, often of metal, used to cover, conceal, decorate, or protect an opening; common also on furniture.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
