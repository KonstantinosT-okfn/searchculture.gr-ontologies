    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Short poems or prose compositions in which text is arranged so that the first letters of each line form a word, phrase, or motto.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
