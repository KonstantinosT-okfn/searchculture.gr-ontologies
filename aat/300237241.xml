    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Physicians specializing in the branch of medicine called ophthalmology. For those trained in the practice of optometry, use "optometrists."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
