      <Descriptive_Note>
        <Note_Text>Eenvoudige vorm van de Romeins-Dorische orde, zonder cannelures.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
