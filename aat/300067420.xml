    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to the architectural order characterized by unfluted columns, torus bases, unadorned cushion capitals, and plain friezes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
