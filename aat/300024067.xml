    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Metal cylinders with teeth cut on one end; used for cutting cylindrical objects or discs from wood, horn, metal, and other materials.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000036401/Salaman, Dictionary of Tools Used in Woodworking (1975)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Metalen cilinders met tanden aan één kant. Worden gebruikt voor het snijden van cilindervormige objecten of schijven uit hout, hoorn, metaal en andere materialen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
