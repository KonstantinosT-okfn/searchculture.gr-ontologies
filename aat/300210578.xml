    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Rectangular pads, generally filled with horsehair, stitched into the top back of the skirt to act as a bustle.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
