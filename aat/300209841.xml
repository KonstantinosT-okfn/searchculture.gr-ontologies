    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Long sleeveless cloaks of ancient Rome, usually having hoods and sometimes front openings.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
