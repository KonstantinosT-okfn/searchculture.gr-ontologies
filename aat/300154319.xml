    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Settlement areas lying at the periphery of cities or suburbs where urban land uses meet rural land uses.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
