    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Genus comprising 10 to 12 species of coniferous trees native to cool and sub-Arctic parts of the northern hemisphere.</Note_Text>
        <Note_Language>English</Note_Language>
