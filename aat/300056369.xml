    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The surface or part of a composition that appears to be farthest from the viewer and against which represented objects or forms are perceived.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
