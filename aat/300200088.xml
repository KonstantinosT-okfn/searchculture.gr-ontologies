    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Watches meant to be carried in pockets, as opposed, for example to be worn on the wrist or carried on chains.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
