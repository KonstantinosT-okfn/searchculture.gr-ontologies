    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Describes works created by the African people of the same name living in Burkino Fasa, related to the Nuna but living in an area north of them.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
