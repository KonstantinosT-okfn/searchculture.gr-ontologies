    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Glaze used predominantly in Japan for stoneware but first developed in China during the Sung Dynasty; characterized by its dark black and brown coloration and streaking largely attributable to the iron-oxide it contains.  </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
