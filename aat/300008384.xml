          <Note_Source>
            <Source>
              <Source_ID>2000079740/AS-Academia Sinica data (2014-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
    </Descriptive_Notes>
