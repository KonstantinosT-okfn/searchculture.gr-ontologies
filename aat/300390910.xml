    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Blessings for the home, including cards and plaques, often displayed near the entrance of the home. Common to several cultures. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
