    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tripod, often tilt-top, circular tables whose top has a scalloped, molded rim resembling the edges of a pie.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
