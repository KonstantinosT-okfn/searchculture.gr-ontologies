    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Chinese ritual bronze vessels formed as steamers with perforated plates between the lower lobed stand and upper basin.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000047624/Rawson, Chinese Bronzes (1987)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Een type Chinees ritueel vaatwerk van brons in de vorm van een stoompan met een geperforeerde plaat tussen de lagere gelobde standaard en de hogere kom.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
