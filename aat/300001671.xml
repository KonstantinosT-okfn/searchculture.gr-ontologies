    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Capitals having interlaced bands resembling the weave of a basket; found in Medieval and Byzantine architecture.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
