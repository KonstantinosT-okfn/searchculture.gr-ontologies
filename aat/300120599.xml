    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Settlement areas possessing a harbor and terminal facilities used for loading or unloading, or water transportation. By extension, the term is also applied to such areas facilitating air transportation.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
