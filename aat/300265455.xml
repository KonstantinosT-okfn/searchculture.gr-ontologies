    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Large size of drawing paper measuring approximately 34 by 26 inches. The term "atlas paper" was originally used to refer to what is now known as "map paper". </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
