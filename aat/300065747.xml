    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>In technical drawing and other contexts, broken lines indicating alternative position of delineated parts or the relative position of an absent part.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
