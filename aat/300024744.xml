    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Pincerlike hand tools with scissors action, usually with serrated jaws; used for gripping, holding, bending, and cutting.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
