      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Baldosa de loza de fabricación española, pintada y esmaltada con colores vivos.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
