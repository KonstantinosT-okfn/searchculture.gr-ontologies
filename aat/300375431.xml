        <Parent_String>Mangifera (genus) [300375430], Anacardiaceae (family) [300375321], Sapindales (order) [300343937], Rosanae (superorder) [300419947], Magnoliopsida (class) [300375593], Angiospermae (division) [300265706], Plantae (kingdom) [300132360], Eukaryota (domain) [300265677], living organisms (entities) [300390503], Living Organisms (hierarchy name) [300265673], Agents Facet [300264089]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
