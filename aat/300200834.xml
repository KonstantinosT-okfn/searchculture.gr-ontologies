    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small balls of perforated metal or other material in which tea leaves are placed to be immersed in hot water to make tea.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
