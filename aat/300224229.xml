    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Dress appropriate for a ball, masquerade, or the like, usually characteristic of a particular period or place, class of persons, or a historical or fictional character.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
