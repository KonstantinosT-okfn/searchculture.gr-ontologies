    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Power-driven saws, usually hand-held, with a protruding arm that carries an endless chain into which the cutting teeth are set.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
