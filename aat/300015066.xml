    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tempera in which the vehicle is made with a water-in-oil emulsion, instead of the more usual oil-in-water emulsion.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
