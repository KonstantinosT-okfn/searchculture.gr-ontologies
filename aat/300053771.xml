  <Subject Subject_ID="300053771">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300053844</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>finishing (process) [300053844], finishing and refinishing processes [300248886], processes and techniques by specific type [300053003], Processes and Techniques (hierarchy name) [300053001], Activities Facet [300264090]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
