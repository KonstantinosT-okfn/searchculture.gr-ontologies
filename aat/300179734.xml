    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Exposing to acid relatively large, unbounded areas of a printing plate, as opposed to relatively small, restricted areas, such as lines.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
