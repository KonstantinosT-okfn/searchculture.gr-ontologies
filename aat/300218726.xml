        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>texture (physical attribute) [300056362], attributes and properties by specific type [300226808], Attributes and Properties (hierarchy name) [300123559], Physical Attributes Facet [300264087]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
