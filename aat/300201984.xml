    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Spanish glass drinking vessels with a single long spout from which liquid (usually wine) may be poured into the drinker's mouth without the glass touching the lips.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
