    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Bookbinding sewing in which the needle is passed through leaves or gatherings placed face to face with the edges together.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
