    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lighting devices consisting of rush, with most of the outer skin or cortex peeled off, dried and saturated in hot grease or fat, and burned for light.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
