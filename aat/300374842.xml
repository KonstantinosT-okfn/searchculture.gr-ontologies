    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Family of trees and shrubs placed in four genera with about 490 species, found throughout the tropics and some also in temperate regions.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
