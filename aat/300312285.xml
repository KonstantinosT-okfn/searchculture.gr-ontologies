    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Institutions of higher learning that provide general or liberal arts education leading to bachelor's degrees; may be independent or parts of universities.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
