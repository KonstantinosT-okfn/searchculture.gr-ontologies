    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Strips of material, often the waste ends of the back lining or endsheets, their width extending from the book shoulder onto the board a short way; they are adhered to the boards as a means of board attachment.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
