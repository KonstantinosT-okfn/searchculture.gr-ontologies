        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Investigación científica y sistemática y estudio de la música y áreas relacionadas, incluyendo historia, teoría, educación musical, acústica y aspectos sociales y culturales.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
