    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Silver coins of ancient Persia equal to one twentieth of a daric and struck from about 515 to 331 BCE.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
