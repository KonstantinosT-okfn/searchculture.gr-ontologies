    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Those trained in the practice of optometry. For physicians specializing in the branch of medicine called ophthalmology, use "ophthalmologists."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
