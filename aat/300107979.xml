    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Comparatively small open areas attached to a house or other building or enclosed by it, and open to the sky; sometimes walled.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
