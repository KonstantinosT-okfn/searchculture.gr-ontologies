    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Cleaning to such an extent that the original finish, patina, or surface layers of an object have been damaged or removed.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
