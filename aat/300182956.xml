    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Candles lit in recognition of a vow, prayer, or desire. Examples are those found in churches, often housed in glass containers. Any candles housed in glass containers that resemble the votive candles originally found primarily in churches and other religious contexts.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
