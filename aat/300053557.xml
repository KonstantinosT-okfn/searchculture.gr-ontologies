    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Photographic processing procedure used to increase the density of a processed negative or print to enhance overall density or contrast.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000099620/Legacy AAT data</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Úsese para el procedimiento de revelado fotográfico utilizado para aumentar la densidad de un negativo o impresión procesados con el fin de aumentar la densidad o el contraste global.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
