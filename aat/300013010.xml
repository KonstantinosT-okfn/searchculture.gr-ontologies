    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Liquefied petroleum gas, marketed under pressure in steel cylinders as bottled gas; used especially in cook stoves.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
