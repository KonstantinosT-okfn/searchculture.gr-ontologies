    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The right or condition of permanent and absolute tenure of land or property with freedom to dispose of it at will; examples include freehold in fee simple, fee-tail, or for term of life.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
