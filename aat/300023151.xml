    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Hammers of various designs having two opposite cutting or hammering edges; used especially by metal workers and stone masons.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
