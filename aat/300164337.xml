    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Partitioned cases constructed to hold a specific number of square wine bottles, made especially during the late 18th and 19th centuries.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
