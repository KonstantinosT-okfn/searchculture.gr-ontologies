    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>May be used broadly for any consecrated place in ancient Roman or Christian architecture, but more specific terms are preferred, such as "chapels," "shrines," "sacristies," or "sanctuaries."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
