      <Descriptive_Note>
        <Note_Text>Se refiere al grupo de estudios o ramas del conocimiento concernientes con hechos y fenómenos del mundo observable y cuantificable, organizado sistemáticamente y mostrando las operación de las leyes generales.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
