        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>Hindu temple spaces [300266136], temple spaces [300004651], religious building spaces [300004559], rooms and spaces by building type [300100051], rooms and spaces [300133704], built work divisions [300072553], components by specific context [300241584], components (objects parts) [300241583], Components (hierarchy name) [300241490], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
      </Preferred_Parent>
