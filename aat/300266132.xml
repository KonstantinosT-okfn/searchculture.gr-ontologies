    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Literally: "womb-" or "embryo chambers." The inner, or main sanctum of a Hindu temple where the object of worship; either an image or linga, is venerated.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
