    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Covered pans for roasting meats or similar foods, often in the form of oval enameled pans with two handles on the side and a domed cover.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
