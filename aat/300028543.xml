            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Gestructureerde verzamelingen van logisch verwante, meestal machinaal leesbare gegevens, bestemd voor verschillende toepassingen, maar onafhankelijk daarvan beheerd.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
