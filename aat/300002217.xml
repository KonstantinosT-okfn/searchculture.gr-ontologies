            <Source>
              <Source_ID>2000113770/AAT-Ned (1994-)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000052396/Koch, Europese bouwstijlen (1988)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>In der klassischen Architektur und ihren Abwandlungen Ornament am Dachfirst oder an der Traufe, das die vordere Öffnung einer Deckziegelreihe abschließt oder verdeckt.</Note_Text>
        <Note_Language>German</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000232/IfM-SMB-PK</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
