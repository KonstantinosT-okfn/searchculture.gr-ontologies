    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A reflective surface quality less bright than a gloss and giving less of an impression of depth in the finish than a luster.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
