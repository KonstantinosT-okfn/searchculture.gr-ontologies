    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Genoese gold coins struck from 1252 until the early 15th century; for similar coins issued in Florence at the same time, use "florins."</Note_Text>
        <Note_Language>English</Note_Language>
