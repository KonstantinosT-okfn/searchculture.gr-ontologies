    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ground-level columns or piers, either external or externally visible, which create a feeling of openness beneath an elevated building mass, as in the architecture of Le Corbusier and his followers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
