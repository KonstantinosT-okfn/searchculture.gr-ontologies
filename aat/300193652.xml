    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Large, oval, Japanese gold coins used primarily for court transactions and issued with various values between the later 16th century and the 19th century.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
