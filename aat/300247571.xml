    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Personal articles, such as furnishings, equipment, or dress, especially those belonging to a soldier, but excluding weapons.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
