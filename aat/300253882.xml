    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Any solid, liquid, or gaseous by-product that is destructive to the environment or dangerous to the health of people or animals.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
