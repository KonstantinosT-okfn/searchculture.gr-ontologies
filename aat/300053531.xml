    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A variant of the wet collodion process producing a direct positive image on a thin sheet of lacquered metal (usually iron, never tin).</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
