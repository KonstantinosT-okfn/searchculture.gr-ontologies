    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A rectangular brick, one end of which has been cut off diagonally to half the width of the brick; used as a closer in masonry.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
