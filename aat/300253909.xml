    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Motifs of human faces surrounded with foliage, in many cases with leaves appearing to sprout from the mouth, nostrils, and sometimes the eyes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000024841/Lewis and Darley, Dictionary of Ornament (1986)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Motivos de rostros humanos rodeados con follaje, en algunos casos con hojas que parecen brotar de la boca, de las ventanas de la nariz y algunas veces de los ojos.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
