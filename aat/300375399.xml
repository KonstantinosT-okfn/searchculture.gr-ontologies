    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small projections located at the axil of a leaf, composed of tiny leaves resembling scales, and forming the rudiment of a branch, cluster of leaves, or blossom. Applied to a flower or leaf at any stage of growth until fully opened.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
