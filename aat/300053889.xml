    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Pottery covered with a lead glaze and fired at a very low temperature, leaving the body soft and porous; originally developed in Japan.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
