    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Beams composed of a stem and a flange so that their section resembles a T, usually of rolled metal.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000027101/Smit, Means Illustrated Construction Dictionary (1985)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Wordt gebruikt voor balken die bestaan uit een steel en een flens zodat hun doorsnede op een T lijkt; meestal van gewalst metaal.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
