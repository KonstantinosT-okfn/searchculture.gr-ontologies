    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Drawings of plumbing systems or parts thereof. For scaled floor plans specifically, use "plumbing plans."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
