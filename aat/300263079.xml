        <Parent_String>philanthropists [300025854], people by activity [300025825], people (agents) [300024979], People (hierarchy name) [300024978], Agents Facet [300264089]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
