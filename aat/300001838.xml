    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Members placed across the inside of an angle in a framework to add stiffness to the framework, as between roof members and wall members.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
