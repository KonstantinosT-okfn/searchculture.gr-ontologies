    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Chairs with interwoven splats in the form of interlaced ribbons, such as those popularized by Chippendale and appearing in mid-18th century England and America.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
