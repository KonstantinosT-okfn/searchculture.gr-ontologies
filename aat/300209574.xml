        <Parent_String>poachers [300221001], cookware [300201279], vessels for cooking food [300229645], containers for cooking food [300198759], culinary containers [300197577], containers by function or context [300197200], containers (receptacles) [300197197], Containers (hierarchy name) [300045611], Furnishings and Equipment (hierarchy name) [300264551], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
