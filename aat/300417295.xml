    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Style and culture of the Mexica people who were part of the Aztec Triple Alliance and whose capital was at Tenochtitlan.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
