    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Narrow streets, usually wide enough for only one vehicle or for pedestrians, passing between buildings or giving access off of main streets to back entrances or garages.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
