    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Rattles composed of small objects such as shells, seeds, or hoofs, strung on cords or tied in bundles.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
