        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>Hydrozoa (class) [300311092], Cnidaria (phylum) [300265921], Animalia (kingdom) [300249395], Eukaryota (domain) [300265677], living organisms (entities) [300390503], Living Organisms (hierarchy name) [300265673], Agents Facet [300264089]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
      </Preferred_Parent>
