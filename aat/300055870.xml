    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The practice of referring to intangible or religious concepts through architectural proportion or repetition of forms in works of art.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
