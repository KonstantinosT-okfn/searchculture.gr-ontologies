        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>paste (glass) [300010803], flint glass [300010802], lead glass [300010811], glass by composition or origin [300010799], glass (material) [300010797], inorganic material [300010360], materials by composition [300212963], materials (substances) [300010358], Materials (hierarchy name) [300010357], Materials Facet [300264091]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
