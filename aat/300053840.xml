        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>subtractive processes and techniques [300229471], processes and techniques by specific type [300053003], Processes and Techniques (hierarchy name) [300053001], Activities Facet [300264090]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
