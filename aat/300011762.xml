            <Source>
              <Source_ID>2000051034/TAA database (2000-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Zuur dat wordt gebruikt om goud en platina op te lossen of te testen; het bestaat uit drie delen zoutzuur en één deel salpeterzuur.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
