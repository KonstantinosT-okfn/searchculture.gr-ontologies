    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Acid used for dissolving or testing gold and platinum; consisting of three parts hydrochloric acid and one part nitric acid.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
