      <Descriptive_Note>
        <Note_Text>Tipo de plástico que se caracteriza por su resistencia a ambientes agresivos, incluyendo climas extremos y temperaturas cercanas a 0 y hasta 260 grados Celsius.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
