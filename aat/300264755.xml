    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Depictions rendered from a vantage point directly above the object, building, or site, but not so high as an "overhead view." For depictions specifically of a building or site from above, prefer "plan views."</Note_Text>
        <Note_Language>English</Note_Language>
