    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Term generally applied to any Windsor chair, of square or round back, having a central vertical back splat.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
