    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The discipline of design for the stage, including design of all visual aspects of a stage production, such as scenery, properties, lighting, costume, and makeup. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000050615/IFLA Glossary for Art Librarians (1984)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Diseño de todos los aspectos visuales de una escenario, producción, incluyendo escenografía, propiedades, iluminación, vestuario y maquillaje.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
