    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Posts, usually mounted on the roadside or at intersections, bearing a sign or signs for the guidance of travelers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
