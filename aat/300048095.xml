    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Interlocking joints formed by a flaring or fanlike tenon and a mortise into which it fits tightly.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
