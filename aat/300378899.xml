    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Having the shape or form of a hemisphere, which is one of two portions of a sphere cut off by a plane through its center.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
