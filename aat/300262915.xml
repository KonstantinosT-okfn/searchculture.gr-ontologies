    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Comics that tell stories intended to be entertainingly frightening, usually featuring such things as monsters, violence, and the supernatural.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
