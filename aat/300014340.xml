    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>An unconsolidated deposit of semicarbonized plant remains formed in a water-saturated environment such as a bog.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
