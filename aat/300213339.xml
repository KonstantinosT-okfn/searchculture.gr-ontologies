    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Simple unpolymerized compounds, having low molecular weight as distinguished from dimers or polymers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000016491/Gettens and Stout, Painting Materials (1966)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Forma simple no polimerizada de un compuesto con un bajo peso molecular, para distinguirlo de un dímero o de un polímero.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
