    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Door locks whose spring bolts are operated by one or more knobs, but whose dead bolts are actuated by a key.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
