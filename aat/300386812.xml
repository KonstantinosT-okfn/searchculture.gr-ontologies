    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Photography using digital cameras, which are cameras that acquire images via an electronic sensor and storing them as digital information on a memory device.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
