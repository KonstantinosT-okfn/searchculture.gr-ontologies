    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Buildings that house schools, usually associated with Christian churches and mainly for children, in which religious instruction is given on Sundays.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
