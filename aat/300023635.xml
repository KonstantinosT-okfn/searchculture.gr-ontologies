    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Hand tools with a handle, crank, and chuck; used for turning a bit or auger to drill a hole by hand.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
