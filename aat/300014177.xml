    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Typically refers to strong paper usually made from mixed pulps that is used for packing or wrapping parcels.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
