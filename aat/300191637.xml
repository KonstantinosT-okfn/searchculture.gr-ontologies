    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The presence or manifestation of two opposite or contrasting principles or tendencies, as for example in electric batteries and in magnets.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
