    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Bookbinding technique in which slanted cuts are made across the back edge of the text block, through which threads are passed and secured by adhesive.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
