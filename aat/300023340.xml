    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Flat tongs whose faces are shaped to pull or grip wire; used in welding clips and in horseshoeing.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
