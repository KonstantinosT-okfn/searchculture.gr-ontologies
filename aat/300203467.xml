    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Those parts of containers that enclose the contents, as distinguished from accessory components such as covers, handles, and applied decoration.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
