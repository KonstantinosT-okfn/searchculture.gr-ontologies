    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Roman bronze or brass coins worth two asses minted from the early third century BCE until the mid-3rd century CE.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
