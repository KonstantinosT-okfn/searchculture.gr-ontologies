    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Primarily outdoor areas where a variety of plants are grown and displayed for scientific, educational, or artistic purposes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
