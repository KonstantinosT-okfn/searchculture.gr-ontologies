    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Variable red colors resembling the color of cochineal colorant, derived from scale insects of the New World.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
