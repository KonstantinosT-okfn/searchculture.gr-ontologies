    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Anthropomorphic basaltic stone monoliths referring to dead legendary figures and found in localized areas in the Middle Cross River region of Nigeria, Africa.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
