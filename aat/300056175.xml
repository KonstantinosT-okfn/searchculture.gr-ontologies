    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The color of a pigment or paint when viewed by transmitted light or when spread thinly over, or mixed with much white.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000016491/Gettens and Stout, Painting Materials (1966)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Color de un pigmento o pintura cuando es vista a través de luz transmitida, o cuando es esparcida en una capa delgada o combinada con mucho blanco</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
