    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>General term for material from the leaves and stems of several species of large aquatic grass used by Native Americans in house construction, making mats, rafts, etc. From the Nahuatl word, "tolin." </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
