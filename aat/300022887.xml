    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Leather-working tools used to produce two parallel surface lines or furrows on a piece of leather by means of two adjustable spring jaws set open with a screw to make guide-llines at any required distance apart.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
