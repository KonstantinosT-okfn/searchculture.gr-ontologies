    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ventilation systems that depend on natural atmospheric conditions and the manual operation of building openings, such as windows, doors, and transoms.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
