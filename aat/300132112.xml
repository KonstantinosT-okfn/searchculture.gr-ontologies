    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Vertical or return piping in plumbing systems; for vertical mains for soil, waste, or venting, use "stacks."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
