    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Seats in postclassic central Mexico, usually made of mats made of thick reeds. Used as a metaphor for the power and authority of the ruler.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000320/GRI-FloCo</Contributor_id>
          </Note_Contributor>
          <Note_Contributor>
