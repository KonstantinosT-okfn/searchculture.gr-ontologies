    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Inflated spherical balls bounced or thrown in the game of the same name; generally about 30 inches in circumference and weighing 20 to 22 ounces.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
