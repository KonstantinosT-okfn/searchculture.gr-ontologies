    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A suspension in a liquid of relatively fine particles of matter, which have no particular propensity to dissolve or combine with the liquid.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
