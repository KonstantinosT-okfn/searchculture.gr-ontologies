    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A range of brownish yellow colors resembling the color of asphaltum, an asphalt-based pigment.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
