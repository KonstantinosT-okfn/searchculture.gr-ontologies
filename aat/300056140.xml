      <Descriptive_Note>
        <Note_Text>Kleuren die ontstaan door vermenging van twee primaire kleuren, in het bijzonder oranje, groen en violet.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
