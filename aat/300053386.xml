    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Painting of images in monochrome, usually gray tones; employed in paintings, stained glass, enamels, and on pottery and other objects.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
