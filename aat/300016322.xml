    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Describes works produced by the African ethnic group of the same name inhabiting the Democratic Republic of the Congo at the confluence of the Lulua and Kasai Rivers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
