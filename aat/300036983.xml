            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Bijlen ontworpen om mee te strijden.</Note_Text>
        <Note_Language>Dutch</Note_Language>
