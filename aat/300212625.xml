    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Land vehicles with armorplated bodies and extra strong doors, locks, and windows, such as trucks for carrying money and valuables or automobiles specially designed for dignitaries.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
