    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>For glassmaking, multipartile molds with a decorative pattern; glass blown into this type of mold picks up the pattern on its exterior.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000038561/Spillman, Glass Tableware (1982)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Bij glasproductie verwijst dit naar meerdelige mallen met een decoratief patroon; als glas in dit type mal wordt geblazen, neemt het aan de buitenkant het patroon over.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
