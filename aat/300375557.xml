        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>Asterales (order) [300375558], Magnoliopsida (class) [300375593], Angiospermae (division) [300265706], Plantae (kingdom) [300132360], Eukaryota (domain) [300265677], living organisms (entities) [300390503], Living Organisms (hierarchy name) [300265673], Agents Facet [300264089]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
