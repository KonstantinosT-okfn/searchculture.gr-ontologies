    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Elements in a pictorial composition that lead the eye step-by-step back into depth, such as side-pieces in a stage set.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
