    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Having the form or outline of an octagon, which is a plane figure with eight sides and eight angles.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
