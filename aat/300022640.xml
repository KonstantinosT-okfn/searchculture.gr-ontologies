    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Early type of camera consisting of a lightproof box, with lens, shutter, and viewfinder, and employing film rather than a plate.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000018681/Haller, Collecting Old Photographs (1979)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Vroege versie van een camera, bestaande uit een lichtdichte doos met een lens, sluiter en beeldzoeker en gebruik makend van een film in plaats van een plaat.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
