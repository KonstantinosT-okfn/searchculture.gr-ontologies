  <Subject Subject_ID="300054238">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300054573</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>cross- and interdisciplinary fields [300054573], disciplines (concept) [300054135], Disciplines (hierarchy name) [300054134], Activities Facet [300264090]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
