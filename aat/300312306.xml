    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Museums specializing in the history of postage stamps, revenue stamps, stamped envelopes, postmarks, post cards, covers, and similar materials relating to postal or fiscal history.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
