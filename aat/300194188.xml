        <Parent_String>Later Western World coins by denomination name [300204267], Later Western World coins [300194573], coins by origin [300037223], coins (money) [300037222], money by form [300264712], money (objects) [300037316], exchange media (objects) [300387350], Exchange Media (hierarchy name) [300037221], Visual and Verbal Communication (hierarchy name) [300264552], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
