    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to devices used to amplify or otherwise modify electrical current via the flow of electrons in an evacuated glass tube or bulb.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
