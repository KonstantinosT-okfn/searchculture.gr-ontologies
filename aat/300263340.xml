    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Human activity that produces the goods or provides the services in demand in an economy. For the people who perform labor, use "workers."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
