    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>People who belong to the cabinet, comprising the confidential advisors and policy-makers of the head of state of a country, and who usually head government departments, as in the United States.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
