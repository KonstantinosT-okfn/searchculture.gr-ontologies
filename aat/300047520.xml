    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Japanese clay or terracotta cylinders surmounted by modeled figures or heads, placed in a fencelike position around burial mounds.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
