  <Subject Subject_ID="300008618">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300008601</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>utilities (infrastructures) [300008601], infrastructural systems [300155846], systems by function [300242038], systems (equipment) [300008550], Object Groupings and Systems (hierarchy name) [300241489], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
