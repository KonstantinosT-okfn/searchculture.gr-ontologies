    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A size of card photograph on a mount measuring 8 1/2 by 5 1/2 or 8 1/4 by 5 inches; popular from the 1870s to 1890s.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
