        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>geology [300054546], earth sciences [300054542], physical sciences [300054532], natural sciences [300233656], science (modern discipline) [300054462], science and related disciplines [300247257], disciplines (concept) [300054135], Disciplines (hierarchy name) [300054134], Activities Facet [300264090]</Parent_String>
