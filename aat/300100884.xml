    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Use to refer to works produced by a group of nine Bantu-speaking peoples of coastal Kenya who share a common history and culture.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
