    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Any process by which small pieces of one material are inserted into a larger piece of another so as to create a design.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000046691/Lucie-Smith, Thames &amp; Hudson Dictionary of Art Terms (1986)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Cualquier proceso por el cual pequeñas piezas de un material son insertadas en una pieza mayor de otro para crear un diseño.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
