    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A residual product of rock decay that is red in color and has a high content in the oxides of iron and hydroxide of aluminum and a low proportion of silica. Used in African and Asian building construction.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
