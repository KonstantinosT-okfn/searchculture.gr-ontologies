          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Blaasinstrumenten met tenorbereik en enkel riet; 19e eeuw.</Note_Text>
        <Note_Language>Dutch</Note_Language>
