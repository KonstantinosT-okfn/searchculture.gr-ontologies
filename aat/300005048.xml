    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Barriers in the form of trenches or sunken fences; usually used to prevent livestock from crossing.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
