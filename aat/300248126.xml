            <Source>
              <Source_ID>2000113770/AAT-Ned (1994-)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000052381/Van Dale Engels-Nederlands (1989)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>مادة شفافة لامعة مصنوعة من السليلوز المتجدد، وعادة ما تكون على شكل صفائح رقيقة، وعادة ما تكون مقاومة للرطوبة ومصبوغة في بعض الأحيان؛ تستخدم كمانع للغازات وتجفيف الشحوم والبكتيريا، ويستخدم كتغليف أو تغليف للأغذية والبضائع الأخرى، وغلاف النوافذ ، وأكياس التصفية.</Note_Text>
        <Note_Language>Arabic </Note_Language>
