    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Weapons featuring a sharp edge or point for cutting, thrusting, clubbing, slashing, or various combinations thereof.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
