              <Source_ID>2000114707/Oxford English Dictionary Online (2002-)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000093795/Encyclopedia Britannica Online (2002-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Esculturas exentas representando figuras humanas o animales o grupos de pequeñas figuras.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
