    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Left-over or superfluous material or by-product not useful to the work or process at hand, as from construction, printing, manufacturing, or industry.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
