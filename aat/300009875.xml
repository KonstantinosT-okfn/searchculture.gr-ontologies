    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Motifs depicting a heart with flames erupting from it or surrounding it. It occurs in Western and Christian art symbolizing charity, divine love, or religious fervor.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
