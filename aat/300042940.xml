    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Vessels that can float and are constructed for travel or transport on the water, such as a boat, ship, or raft.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000114707/Oxford English Dictionary Online (2002-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Vaartuigen die kunnen drijven en die zijn gebouwd om over het water te reizen of zaken te vervoeren, bijvoorbeeld een boot, schip of vlot.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
