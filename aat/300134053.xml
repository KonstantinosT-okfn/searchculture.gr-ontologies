    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tables having single slab of marble as a top surface. The form was particularly popular in the 18th century.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
