    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The length of a straight line passing through the center of a circle or sphere, terminated at each end by its circumference or surface.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
