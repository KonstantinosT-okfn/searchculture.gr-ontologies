    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The level corresponding to the surface of the sea at mean level between high and low tides, used as a standard for the measurement of heights.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
