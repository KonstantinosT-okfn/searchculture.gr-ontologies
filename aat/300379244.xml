    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Units of time equivalent to nearly 365.25 days, 12 months, or the period of one full circuit of the Earth around the Sun. </Note_Text>
        <Note_Language>English</Note_Language>
