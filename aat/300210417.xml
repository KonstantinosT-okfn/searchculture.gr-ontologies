    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Rectangular pieces of white cloth, usually linen, worn around the neck and partly under the alb; designed to protect other vestments from perspiration.</Note_Text>
        <Note_Language>English</Note_Language>
