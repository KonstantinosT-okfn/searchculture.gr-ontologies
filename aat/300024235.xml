    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tools used by coopers to insert a cooper's flag between the head and staves of a barrel after the head is in place.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
