    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Diagrams using labeled blocks connected by straight lines to represent the relationship of parts or phases.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
