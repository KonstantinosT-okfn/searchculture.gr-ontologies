    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Paintings or sculptures portraying Zen priests. These portraits are known for having particularly expressive faces.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
