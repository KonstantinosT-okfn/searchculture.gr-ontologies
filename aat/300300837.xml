    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to relatively small reliquaries in the form of a rectangular box surmounted by a steeped-roof.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
