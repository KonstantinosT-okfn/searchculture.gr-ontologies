    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Slender, compressed cylinders of material often made from calcium sulfate in its dihydrate form, gypsum. Most often used to write on blackboards or chalkboards in classroom contexts, but also for many other marking purposes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
