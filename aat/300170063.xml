        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Windsor-leunstoelen met een lage rugleuning op armhoogte die meestal  bestaat uit een uitgezaagde driedelige armleuning die de buitenrand van de zitting volgt.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
