    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Photographic processes in which albumen is used as the binder. Common for photographic prints and occasionally for lantern slides, but rarely used for negatives on glass.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
