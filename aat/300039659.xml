    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Extension dining tables invented during the Victorian period, which received their name from the slide action by which their length is varied.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
