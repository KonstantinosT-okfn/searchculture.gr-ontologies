    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The joints that connect the foot with the leg of a human or an animal; also used for the larger area comprising the slender part of the leg between this joint and the calf.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
