    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A brick which has been cut to one-fourth of its normal length but is of normal thickness and width; used to space normal-sized brick.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
