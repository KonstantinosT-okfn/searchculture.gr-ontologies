    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tall wooden drums used by Aztecs. Instead of using mallets, players strike the tops of the huéhuetls with their fingers or hands. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
