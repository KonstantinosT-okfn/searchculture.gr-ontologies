    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A fine-grained white marble from Vermont that is highly valued by sculptors; it may contain bluish-gray veins or clouds.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
