    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>General term for wood from any of several species of tree or shrub having ornamentally striped wood used by cabinet-makers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
