    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Pads, ruffles, or shaped inserts placed inside a corset or brassiere to fill out the bust.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
