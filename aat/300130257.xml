    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Hue name for the colors intermediate between red and blue, originally the colors derived from a crimson mollusk dye.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
