            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Naam voor kleurschakeringen tussen rood en blauw, oorspronkelijk gebruikt voor een karmozijnrode kleurstof afkomstig van weekdieren.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
