    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A brilliant, highly reflective surface quality, giving a more mirrorlike reflected image than a lustrous or shiny surface.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
