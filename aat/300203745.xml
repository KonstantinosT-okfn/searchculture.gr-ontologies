    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A combination of café curtains across the lower part of an opening and tieback curtains, usually ruffled, across the top.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
