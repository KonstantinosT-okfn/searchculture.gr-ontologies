    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Painting done on the front or the reverse of glass, whether or not the paint is then fired onto the glass. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
