    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The western ends of certain Carolingian and Ottonian churches, having an entrance hall, upper-level chapel, and towers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
