    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>People who specialize in making sundials, which are instruments that indicate approximate time of day from a shadow cast in sunlight.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
