    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Those officially chosen by a group or organization, such as a government or the regional membership of a political party, to speak or act in its interests or in accordance with its instructions at a convention, conference, or other meeting.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
