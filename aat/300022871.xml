    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Knife-like tool used to stretch lead when joining glass pieces or for bedding glass in wooden rebates.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
