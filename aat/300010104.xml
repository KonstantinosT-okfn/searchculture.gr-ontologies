    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Decorative motifs consisting of isolated or fairly discrete scrolls with foliate forms. For continuing patterns employing these, use "scrolling foliage."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
