    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Family containing 18 genera of submerged and emergent, freshwater and saltwater aquatic herbs, mainly of warmer regions.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
