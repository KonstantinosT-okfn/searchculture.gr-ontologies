    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Supreme and independent authority of a political unit to make and apply laws within its own boundaries and to conduct international relations.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
