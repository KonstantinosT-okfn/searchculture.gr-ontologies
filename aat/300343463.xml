    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Educational institutions at the post-high school level, offering a two-year program of study of a terminal nature or in preparation for continued college studies.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
