    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A translucent red or orange variety of chalcedony, containing iron impurities. An example of use is for seals and signet rings.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
