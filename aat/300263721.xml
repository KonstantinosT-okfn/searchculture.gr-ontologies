    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to a type of sheet glass characterized by a linear relief pattern or texture that is created by using a ridged roller in the manufacturing process.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
