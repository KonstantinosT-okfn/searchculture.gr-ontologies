    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small, usually wire kitchen implements used for hand beating of foods such as eggs, creams, or potatoes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
