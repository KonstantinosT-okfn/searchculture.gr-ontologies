    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Native clay selected for its fineness, plasticity, absorbency, and other qualities that suit it to various ceramic uses.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
