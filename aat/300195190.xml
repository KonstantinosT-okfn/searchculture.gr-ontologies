    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Those parts of a book consisting of the stack of leaves or gatherings to be bound, exclusive of the materials, such as endpapers or boards, that are added in binding.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
