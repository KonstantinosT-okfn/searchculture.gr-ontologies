    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Plans that show the ground surface of a building site or other site, generally including grade elevations and contours.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
