  <Subject Subject_ID="300211206">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300211288</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>fitness and exercise equipment [300211288], recreational artifacts (equipment) [300218781], Recreational Artifacts (hierarchy name) [300136012], Furnishings and Equipment (hierarchy name) [300264551], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
