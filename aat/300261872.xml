    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lever-type cutters often mounted on a flat bed and equipped with a foot-operated clamp; used for cutting boards or similar materials.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
