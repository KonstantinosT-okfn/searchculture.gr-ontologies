    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The technique of analyzing a material for chemical elements by bombarding it with neutrons, charged particles such as protons, or gamma photons.</Note_Text>
        <Note_Language>English</Note_Language>
