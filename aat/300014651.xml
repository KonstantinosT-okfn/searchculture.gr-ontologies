    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A small solid or densely packed rounded, spherical, or cylindrical mass, typically of food or medicine.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
