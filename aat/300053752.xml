    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The separation of small pieces or fragments from an object or surface. May refer to accidental activity or process, or to intentional activity, as with the making of arrowheads.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
