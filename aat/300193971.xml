    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Negotiable documents other than paper money that are supported by coin reserves and provide evidence of current or long-term debt.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
