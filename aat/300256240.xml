    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to the reduction in amplitude, density, or energy, resulting from such effects as absorption, friction, scattering, or thinning.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
