    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Manned or unmanned vehicles designed to be placed in orbit about the earth or into a trajectory toward another celestial body.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
