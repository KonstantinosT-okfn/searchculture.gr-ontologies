        <Parent_String>bloodletters [300261158], ceremonial weapons [300263273], armaments [300420324], weapons [300036926], Weapons and Ammunition (hierarchy name) [300036743], Furnishings and Equipment (hierarchy name) [300264551], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
