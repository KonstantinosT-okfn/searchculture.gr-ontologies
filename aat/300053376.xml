    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A method of painting which produces soft stains or blots of color through the use of heavily diluted paint on unsized canvas.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
