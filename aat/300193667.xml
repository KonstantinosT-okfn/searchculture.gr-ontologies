    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Rugs of any design made by commission on royal or court looms, such as Moghul, Ottoman, or Safavid.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
