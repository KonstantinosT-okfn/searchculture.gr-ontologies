    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Intentionally leaving the marks of a tool on a surface, especially on leather or stone; produced during the finishing or dressing process.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
