    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Use broadly for the capture and transmission of information by detecting devices located at a distance from the receiving device and for the detection of information beyond the reach of normal human capacity.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
