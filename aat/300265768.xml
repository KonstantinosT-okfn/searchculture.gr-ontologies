    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Losing consciousness, due to a drop in blood supply to the brain. Also, a weakening or decline. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
