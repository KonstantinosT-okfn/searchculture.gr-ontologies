    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Script used by the Mycenaeans after about 1500 or 1450 BCE, apparently recording an early form of the Greek language.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
