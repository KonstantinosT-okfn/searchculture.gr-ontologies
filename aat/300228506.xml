    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Locomotives whose motive power source is electricity generated on board or obtained via overhead wires or a third rail.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
