    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Written agreements between masters and minors under which a minor agrees to work for a master for a stated period of time in return for instruction in a trade by a master.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
