    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Bottles intended for poison, varying in shape, but often with a rough texture or other external features so as to be recognized by touch.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
