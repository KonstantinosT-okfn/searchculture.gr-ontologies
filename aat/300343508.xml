    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A detail within a painting that is subordinate to the main theme of the work; an example would be a still life within a portrait painting.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
