    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Geometric plane figures bounded by a single curved line which is everywhere equally distant from the center of the figure.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
