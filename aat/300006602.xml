    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Buildings that house schools intermediate between elementary school and high school, differing by school district in grades included.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
