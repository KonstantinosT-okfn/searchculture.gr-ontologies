    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Printing process whereby material to be printed is stored in an electronic archive, and copies are produced as required by the end user. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
