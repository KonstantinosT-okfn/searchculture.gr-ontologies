    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Symbol in Tibetan Buddhism and related cultures resembling a complex intertwining cord or ribbon, representing eternity.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
