    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Electric lamps in which light is produced by a tungsten filament heated to incandescence by an electric current.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
