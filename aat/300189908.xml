    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Picture frames in which the decoration of corners and centers is emphasized, usually by placement of cartouches.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
