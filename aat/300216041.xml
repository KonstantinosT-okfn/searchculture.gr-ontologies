    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Skirts made of long stems of grass bound to a waistband, traditionally worn by Hawaiian hula dancers.  Also, imitations of such skirts.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
