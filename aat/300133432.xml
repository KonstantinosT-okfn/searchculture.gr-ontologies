            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000052394/Dictionary of Photography (1965)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
    </Descriptive_Notes>
