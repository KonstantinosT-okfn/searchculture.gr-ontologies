    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Instruments for measuring, and often also recording, the amount of water passing a specified point in a piping system.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
