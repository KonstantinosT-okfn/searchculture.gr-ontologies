    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Doctrine espoused by certain French painters of the 18th century emphasizing the importance of line over color.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
