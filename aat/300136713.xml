    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>People who disagree with or take an opposing view to established, orthodox, or majority values or opinions, especially those of a church or political party.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
