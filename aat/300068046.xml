    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Structural systems in which the primary reinforcing steel runs in one direction only; may or may not include one-way supporting beams.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
