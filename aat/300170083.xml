    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Term introduced in the 19th century for any Windsor chair, with or without arms, of a square or nearly square back.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
