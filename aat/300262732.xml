            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Mintadi aus Stein oder Beton, der als Grabmonument auf Gräbern höher gestellter Persönlichkeiten beim Volk der Kongo und in Angola aufgestellt wird.</Note_Text>
        <Note_Language>German</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000232/IfM-SMB-PK</Contributor_id>
