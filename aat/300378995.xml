    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Decoration used to embellish parts of a building; usually in and of itself having no function, although it may decorate functional members.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
