    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Those who are treated as the property of and are entirely subject to another person, whether by capture, purchase, or birth.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
