        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>windows by form [300002946], windows [300002944], windows and window components [300052375], openings by form [300114196], openings (architectural elements) [300002765], openings and opening components [300052369], architectural elements [300000885], components by specific context [300241584], components (objects parts) [300241583], Components (hierarchy name) [300241490], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
      </Preferred_Parent>
