  <Subject Subject_ID="300008394">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300008389</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>cities [300008389], settlements by form [300008350], inhabited places [300008347], Settlements and Landscapes (hierarchy name) [300008346], Built Environment (hierarchy name) [300264550], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
