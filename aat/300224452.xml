    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Material which is an electrical insulator or in which an electric field can be sustained with a minimum of dissipation in power.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
