    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tall Mahafaly wooden sculptures in Madagascar, placed in small groups at tombs, carved with human and animal figures and geometric openwork.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
