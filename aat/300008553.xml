    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to the underlying foundation or basic framework of a system or organization, especially the services and facilities which are an integral part of the life in an urban community.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
