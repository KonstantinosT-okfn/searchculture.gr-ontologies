    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Large inlets of the sea, usually more enclosed and more deeply indented than bays.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
