    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Describes the works produced by the nomadic Arabic-speaking people of the same name, a subgroup of the Bedouin, living in northern Sudan.</Note_Text>
        <Note_Language>English</Note_Language>
