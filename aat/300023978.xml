    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small backsaws, 3 to 6 inches in length, with very fine teeth and very little set; used for fine work.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
