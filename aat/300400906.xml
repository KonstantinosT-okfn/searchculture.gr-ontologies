    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Cultural condition of the coexistence of numerous distinct ethnic and cultural groups within one society. For the cultural movement, use "multiculturalism." For the broader philosophical concept, use "pluralism."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
