    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Flat surfaces in three dimensions such that all points on a line joining any pair of points also belong to the surface.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
