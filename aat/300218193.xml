    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Thin, shaped strips of ivory, bone, wood, or plastic, or tapered sticks used in the game of jackstraws.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
