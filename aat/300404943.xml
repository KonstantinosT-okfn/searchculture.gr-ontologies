    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Collectively refers to the non-noble people in Nahua culture. Frequently associated with commoners, vassals, or peasants from the colonial period forward.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
