            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Burgers of vazallen in klassieke Nahua-culturen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
