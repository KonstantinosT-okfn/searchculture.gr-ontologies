    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Actions or instances of deceit, trickery, or breach of confidence used to acquire unfair or dishonest advantage or material gain.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
