    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Roofs formed by the junction of two gable roofs with a valley between them, resembling the letter M in section.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
