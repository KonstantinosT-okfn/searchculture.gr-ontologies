    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tools used for embossing, as in the stamping of linen book bindings, or gold leaf surfaces. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
