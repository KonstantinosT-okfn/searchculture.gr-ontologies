    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Style and culture of the African ethnic group of the same name currently living in southern Ghana, formerly constituting a famous kingdom.</Note_Text>
        <Note_Language>English</Note_Language>
