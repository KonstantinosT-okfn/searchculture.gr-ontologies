    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Structures based on horizontal, rigid, planar elements, typically of monolithic materials, with depths small in relation to their other dimensions.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
