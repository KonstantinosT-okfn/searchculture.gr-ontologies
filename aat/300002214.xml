    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The figures or ornaments at the lower angles or apex of a pediment, generally supported on plinths.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000011671/Dinsmoor, Architecture of Ancient Greece (1975)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>De figuren of ornamenten op de onderste hoeken of apex van een gevelveld, deze worden in het algemeen gesteund door plinten.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
