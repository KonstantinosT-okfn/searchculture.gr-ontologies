        <Parent_String>people by degree of qualification [300025896], people (agents) [300024979], People (hierarchy name) [300024978], Agents Facet [300264089]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
