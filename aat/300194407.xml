    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Shortened forms of words, names, or phrases that are not words themselves but stand for the original; often created by the omission of letters or the replacement of several letters by a symbol.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
