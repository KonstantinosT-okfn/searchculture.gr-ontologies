    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The juxtaposition of dissimilar elements, properties, or qualities in a work in order to heighten expressiveness through the differences revealed by comparison.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
