    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Medieval picture bibles that are composed of paraphrased passages translated into French, including passages from the "Historia Scholastica" of Petrus Comestor, or of biblical passages juxtaposed with passages from Comestor.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
