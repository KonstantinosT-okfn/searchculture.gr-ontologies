    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Parent companies whose activities are confined to owning stock in and supervising the financial, managerial, or marketing functions of their subsidiaries.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
