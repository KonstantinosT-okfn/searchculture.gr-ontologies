        <Parent_String>measuring devices for forces [300195702], measuring devices (instruments) [300207870], Measuring Devices (hierarchy name) [300207851], Furnishings and Equipment (hierarchy name) [300264551], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
