    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Objects of precious materials and symbolic value, such as jeweled scepters or crowns, appendant to the office of a sovereign.</Note_Text>
        <Note_Language>English</Note_Language>
