    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ancient Greek vessels used for cooling wine, having a body drawn in toward the base and set on a high pedestal or foot.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
