    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Holes, usually with a cover, through which a person may enter sewers, steam drains, or similar underground passages, especially those located in city streets.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
