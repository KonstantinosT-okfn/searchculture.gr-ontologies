    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A type of fine white clay used to make tobacco pipes and fine earthenwares. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
