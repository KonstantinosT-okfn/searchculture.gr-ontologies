    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Chief officers in command of a military force, place, or station. For commissioned officers in the American and British navies ranking immediately below captains, see "commanders."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
