    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Persons who engage in the study and activities concerning the nature, collection, dissemination, and retrieval of data and information, especially in automated environments, or who design information systems.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
