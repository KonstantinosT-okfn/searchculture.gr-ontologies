    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Frameworks of horizontal and vertical bars or timbers specifically designed for children to climb and play on; originally devised in the 1930s.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
