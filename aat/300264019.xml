    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Business machines, usually with money drawers, that record sales, other transactions, and related operations such as totaling receipts and dispensing printed receipts for customers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
