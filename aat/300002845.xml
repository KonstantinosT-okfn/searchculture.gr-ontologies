    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Doors that are flush with and treated in the same manner as the surrounding wall so as to be concealed and have no visible hardware.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
