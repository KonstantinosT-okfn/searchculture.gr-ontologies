    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A type of paving stone generally cut in a slightly pyramidal shape, laid with the base of the pyramid down.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
