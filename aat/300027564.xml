    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Statements showing the income and expense accounts of a business over a stated time, the difference being the profit or loss for the period.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
