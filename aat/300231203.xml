    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Upholstering technique in which nails are set close together to secure the edges of the top cover, also creating a decorative feature.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
