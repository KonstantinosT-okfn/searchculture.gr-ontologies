    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A pattern of short, irregular wriggling channels imitating worm tracks, used as a surface decoration on stone, wood, or another material, to create a rusticated effect.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
