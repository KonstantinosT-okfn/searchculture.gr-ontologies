    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Family containing one species, characterized by being semi-aquatic, having prominent tusks, whiskers, great bulk, being relatively long-lived, and social.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
