    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Limestone containing many small, rounded particles, which are concentric layers of calcium carbonate deposits.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
