    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Cutting or shaping the edge or end of a material to form an angle that is not a right angle. In the context of furniture, prefer "chamfering."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
