    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Straps, or pairs of straps, usually of leather, and attached to the bridle or bit of horses or other animals, used by riders to direct their locomotion.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
