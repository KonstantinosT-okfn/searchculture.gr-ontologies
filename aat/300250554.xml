            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Productos realizados al unir dos o más capas de materiales.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
