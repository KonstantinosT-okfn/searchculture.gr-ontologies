    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A colorless or pale brown mica; it has superior dielectric properties and is valued for radio capacitators.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
