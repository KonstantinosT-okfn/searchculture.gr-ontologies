            <Source>
              <Source_ID>2000113770/AAT-Ned (1994-)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000087845/ID-DOC, MOT</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>把手形式的裝置，具鉗口和可延伸之柄部，用於把釘子拔出木頭。若指具叉狀尾端，用於類似目的之簡易手工具，則稱「拔圖釘器」。</Note_Text>
        <Note_Language>Chinese (traditional)</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000250/AS-Academia Sinica</Contributor_id>
          </Note_Contributor>
