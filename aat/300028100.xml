    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Outline maps showing the important natural and man-made features of an area, to which specific information may be added for any of various purposes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
