    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Rattles in the form of elaborate wood or bronze staffs from the Benin kingdom and other Edo peoples in Nigeria.</Note_Text>
        <Note_Language>English</Note_Language>
