            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000052446/[S]Color Fotovaklab</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
    </Descriptive_Notes>
