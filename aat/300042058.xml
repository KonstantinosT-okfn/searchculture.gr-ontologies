    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Arched harps of the Teso of Uganda and Kenya, with a very slim elongated body and five or six strings.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
