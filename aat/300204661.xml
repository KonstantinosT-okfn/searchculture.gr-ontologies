    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Simple hilts in which the grip and quillons, together with the blade of the weapon, form the outline of a Latin cross.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
