    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Rooms or boxes with a single small opening, with or without a lens, through which an inverted image is projected from outside the box onto the opposite interior wall.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
