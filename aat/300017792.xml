    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Although scholarship refers to cultural products associated with this group as Otomi, the term is an exonym and the people refer to themselves as Hñahñu.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000320/GRI-FloCo</Contributor_id>
          </Note_Contributor>
