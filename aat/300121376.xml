    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Chests made from a hollowed log or tree trunk, and used primarily in the Middle Ages. Frequently used as safes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
