    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Natural trumpets in elongated crescent shape, built in Europe in the early 19th century and designed to accommodate the hand-in-bell playing technique.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
