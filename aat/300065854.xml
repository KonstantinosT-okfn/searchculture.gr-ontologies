    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>In a perspective system, an area where orthogonals converge in a general vicinity rather than a single point.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
