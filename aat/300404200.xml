    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Works of feather mosaic created by Nahua peoples. Objects included cloaks, fans, and shields.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
