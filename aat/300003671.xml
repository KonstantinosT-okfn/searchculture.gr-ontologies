    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Structures built around or upstream from a bridge pier with an angle or edge to resist better the action of water, ice, or flotsam.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
