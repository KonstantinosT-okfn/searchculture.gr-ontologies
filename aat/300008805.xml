    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Extensive areas of land having few inequalities of surface, being usually fairly flat and at low elevation.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
