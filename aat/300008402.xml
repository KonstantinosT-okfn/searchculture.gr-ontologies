    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Great urbanized areas or clusters of urbanized areas produced by the expansion and merging of several neighboring metropolises or conurbations.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
