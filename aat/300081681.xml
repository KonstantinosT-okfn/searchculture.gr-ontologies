        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>bone dating techniques [300081658], dating (measuring process) [300054714], measuring [300053578], analysis and testing techniques [300081683], processes and techniques by specific type [300053003], Processes and Techniques (hierarchy name) [300053001], Activities Facet [300264090]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
