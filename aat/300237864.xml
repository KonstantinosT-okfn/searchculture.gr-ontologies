    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Various techniques of manipulating images in a computer environment, whether by program or by adjusting individual pixels or areas of the image.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
