        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>De vezel van één van twee Spaanse en Algerijnse grassoorten (Macrochloa tenacissima en Lygeum spartum), die vooral wordt gebruikt voor het maken van touwwerk, schoenen en papier.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
