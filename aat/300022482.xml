    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small stumps of tightly rolled gray or white paper, usually pointed at one end only; used to blend charcoal and pastel.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
