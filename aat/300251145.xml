    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Study of pollen grains, spores, and other microscopic plant materials, whether living or fossilized, especially their dispersal and applications in stratigraphy and paleontology.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
