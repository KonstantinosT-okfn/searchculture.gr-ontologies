    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Disciplines concerning arts that depend upon performances presented to the attention of observers through the live or recorded actions of the artists, such as actors, musicians, poets, etc.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
