    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Dams using earth or rock as fill, utilizing natually available materials with minimum processing to construct embankments.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
