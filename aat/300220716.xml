    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A nonreversible condition whereby the fibrous structure of leather breaks down partially or completely, becoming extremely powdery.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
