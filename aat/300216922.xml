    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Combination bifurcated garments for infants and toddlers, close-fitting, usually of knit, extending to the hip. May be made with or without sleeves.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
