        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Beeldende werken ontworpen of uitgekozen om samen te worden getoond.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
