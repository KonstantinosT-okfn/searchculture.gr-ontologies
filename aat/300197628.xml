    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Escapements in which wedge-shaped pallets of an anchor-shaped component engage an escape wheel causing the wheel to recoil slightly at every release.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
