    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Rows of small floodlights mounted on trough reflectors and used for theater borderlights, footlights, and general stage illumination.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
