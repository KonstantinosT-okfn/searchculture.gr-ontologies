    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Fancy Windsor chairs of square-back based on Sheraton's designs, and found in the region of Mendlesham, England in the early 19th century.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
