            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Elegante Windsorstoelen met een vierkante rugleuning naar de ontwerpen van Sheraton. Ze kwamen in Engeland voor in de omgeving van Mendlesham aan het begin van de 19e eeuw.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
