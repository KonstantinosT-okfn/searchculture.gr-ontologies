            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000114707/Oxford English Dictionary Online (2002-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Stukken lood die door kopiisten na de 12de eeuw gebruikt werden om lijnen of schetsen van layouts op perkamentbladen te maken.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
