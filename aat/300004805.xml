        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Gebouwen van meerdere verdiepingen met grote ononderbroken ruimten, oorspronkelijk verhuurd voor lichte industriële doeleinden en nu vaak verbouwd voor bewoning.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
