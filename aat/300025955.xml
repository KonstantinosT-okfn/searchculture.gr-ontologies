    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Unincorporated groups of individuals associated together for purposes of mutual interest or common objectives, commonly but not exclusively commercial or financial.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
