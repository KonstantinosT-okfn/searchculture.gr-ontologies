    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Implements having a flat elongated form with various modifications of shape and size, used for a variety of purposes, such as mixing, stirring, spreading, lifting, or examining.</Note_Text>
        <Note_Language>English</Note_Language>
