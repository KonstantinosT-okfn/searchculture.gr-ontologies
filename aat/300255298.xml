    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The measure, usually in points of the dimensions of type, taken from the body of the individual type, rather than from the actual printing area.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
