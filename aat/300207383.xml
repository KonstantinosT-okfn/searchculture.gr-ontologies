    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Term used in the glass trade for a type of art glass molded in ornate patterns, made in various shades of pink.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
