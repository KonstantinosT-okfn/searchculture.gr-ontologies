    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Windows equipped with removable or interchangeable screen and glass sections that make them suitable for either summer or winter use.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
