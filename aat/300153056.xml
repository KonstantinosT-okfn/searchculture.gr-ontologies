    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Organizations that maintain large online bibliographic databases and offer cataloging support and related products to libraries and other customers who access those databases on an online, time-sharing basis.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
