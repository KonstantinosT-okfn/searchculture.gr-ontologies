    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Computer peripherals composed of a monitor or printing device and a keyboard, which are linked together to function as a single input/output unit.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
