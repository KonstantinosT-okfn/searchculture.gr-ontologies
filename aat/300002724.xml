    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Those parts of the flanking walls of the cella of a temple that project beyond its front or rear, often terminating in antae.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000077471/Sturgis, Dictionary of Architecture and Building (1901)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Die delen van de flankerende muren van de cella van een tempel die uitsteken voorbij de voorkant of achterkant en die vaak eindigen in antae.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
