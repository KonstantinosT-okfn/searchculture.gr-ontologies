            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Een wit tot donkergrijs monoclien mineraal van de amfiboolgroep; vaak een bestanddeel van ongezuiverde talk.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
