        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Wordt gebruikt voor licht railvervoer waarbij spoorwegachtige voertuigen worden voortgetrokken door een bewegende doorlopende kabel of band die zich vaak onder de spoorbaan bevindt.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
