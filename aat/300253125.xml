    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The free end of the cords, thongs, or tapes on which a book has been sewn, that are used to attach the boards or case to the text block.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
