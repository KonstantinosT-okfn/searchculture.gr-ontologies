    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Drinking vessels, usually cylindrical in form and having one handle and sometimes a hinged lid; to reference those intended specifically for beer, use the narrower concept "beer steins."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
