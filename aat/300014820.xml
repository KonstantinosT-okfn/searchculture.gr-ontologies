    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A cold-work, water-resistant paste made from casein by dispersion with a mild base such as ammonia.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
