    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Photographs produced in small, automated picture-taking enclosures; usually requiring automated payment of a small fee to initiate the photographic process.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
