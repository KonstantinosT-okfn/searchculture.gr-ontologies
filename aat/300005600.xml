              <Source_ID>2000099620/Legacy AAT data</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Vivienda unifamiliar de los Navajo, por lo común baja y aproximadamente cónica, construida por lo general de leños y palos cubiertos con lod, césped o adobe.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
