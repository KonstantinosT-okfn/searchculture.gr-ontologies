    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to persons appointed, elected, or otherwise officially authorized to act in place of or as the second-in-command to a ruler, public officer, or executive.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
