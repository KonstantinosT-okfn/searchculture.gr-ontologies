    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Members of a subphylum containing two classes, insects and ametabolous arthropods, with bodies divided into an anterior head, thorax, and posterior abdomen.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
