    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Any chromium steel containing a small amount of vanadium; valued for its combination of strength and ductility.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
