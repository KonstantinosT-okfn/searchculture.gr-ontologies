        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>Islamic World, The [300021516], styles, periods, and cultures by region [300111079], Styles and Periods (hierarchy name) [300015646], Styles and Periods Facet [300264088]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
