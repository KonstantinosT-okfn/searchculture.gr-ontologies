    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Aircraft weighing less than the air they displace, sustaining lift by displacing the air using aerostatic bouyancy.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
