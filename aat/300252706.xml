    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Risking money or other valuable stakes on the outcome of contests or other events whose outcome involves chance and is thus uncertain.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
