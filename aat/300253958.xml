    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Bindings in which the spine and approximately one third the width of the boards are covered, usually in leather or cloth, with disproportionately large corners of the same material.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000099620/Legacy AAT data</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Banden waarin de rug en ongeveer een derde van de breedte van het plat bedekt zijn, meestal met leer of stof, gecombineerd met onevenredig grote hoeken van hetzelfde materiaal.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
