    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Self-supporting and self-governing communities comprised of small groups of people living together with minimal interference from outsiders.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
