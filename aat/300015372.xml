        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>materials by property [300015352], materials (substances) [300010358], Materials (hierarchy name) [300010357], Materials Facet [300264091]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
