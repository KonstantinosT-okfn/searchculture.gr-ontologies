    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Decorative, raised borders of wood or metal extending around the back and sides of a shelf or on the top of a piece of furniture.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
