    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Semi-liquid, loose sand which can suck down heavy objects that rest on its surface.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
