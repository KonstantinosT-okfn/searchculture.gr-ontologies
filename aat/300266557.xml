    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The parta of an open body of water occupying the space between two headlands, generally a shallow or slightly receding bay or slight recession in a coastline.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
