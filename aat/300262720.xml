    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Trousers cut with fullness on both the outer and inner seams to give a flare at the hem. This style was popular in the 1960s and 1970s.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
