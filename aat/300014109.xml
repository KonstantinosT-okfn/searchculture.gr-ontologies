            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Amatl tlachihualli ica ipancuetlayo amate, ce cuahuitl tlen campa quiquixtia huapalli tlen America Central.</Note_Text>
        <Note_Language>Eastern Huasteca Nahuatl</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000320/GRI-FloCo</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
