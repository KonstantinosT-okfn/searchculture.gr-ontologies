    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Powders, lotion, lipstick, rouge, or other preparations to be applied to the human body for the beautifying, preserving, or altering the appearance of a person.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
