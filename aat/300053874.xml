    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Application of a penetrating liquid to fill pores, to isolate coatings, or to make surfaces suitable to receive coatings.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
