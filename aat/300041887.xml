    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Sets of tuned metal tubes hung vertically in a frame and struck with hammers, commonly used for bell effects in the orchestra and on the operatic stage.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000099620/Legacy AAT data</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Series gestemde metalen buizen die verticaal zijn opgehangen in een raamwerk en worden aangeslagen met hamers, meestal gebruikt voor klokgelui-effecten in concerten en opera's .</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
