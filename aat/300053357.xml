    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Mural painting technique in which dry pigments are ground with water then brushed onto wet or partially dry lime plaster. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
