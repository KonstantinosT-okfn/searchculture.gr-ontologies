    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Process of refining precious metals like gold and silver; the impurities are oxidized and partly absorbed into the cupel.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
