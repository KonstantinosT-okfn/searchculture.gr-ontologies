    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Screen process for producing transparencies by additive color synthesis, invented in 1910, in France, by Louis D. Dufay.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
