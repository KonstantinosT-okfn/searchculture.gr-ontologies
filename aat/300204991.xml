    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Instruments for measuring the frequencies of tones or exact pitch, as a set of graduated tuning forks.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
