    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Collections of familiar expressions or sentiments, often attributed to a particular person. Typically used in a more general sense than "epigrams" or "aphorisms."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
