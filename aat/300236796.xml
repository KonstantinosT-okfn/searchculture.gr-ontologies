            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Aquellos que viven una vida de reclusión y soledad.</Note_Text>
        <Note_Language>Spanish</Note_Language>
