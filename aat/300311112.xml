        <Parent_String>artistic devices [300065299], artistic concepts [300168394], concepts in the arts and humanities [300056107], Associated Concepts (hierarchy name) [300055126], Associated Concepts Facet [300264086]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
