    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Quilts illustrating Bible stories or including scriptural quotations, adages, maxims, or proverbs conveying religious or moral precepts.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
