            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Dibujos que representan una sección horizontal a través de un edificio tomado sobre un piso.</Note_Text>
        <Note_Language>Spanish</Note_Language>
