        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Vloeibare tot halfvaste stof die wordt gemaakt in de nier en wordt afgevoerd door de urineorganen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
