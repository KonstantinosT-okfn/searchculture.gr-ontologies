    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Long, fine, usually spiral, springs used to determine the time of oscillation of balance wheels of timepieces.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
