    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Yarn produced by twisting together two or more strands of plied yarn; the final twist is opposite to that of the plied ends.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
