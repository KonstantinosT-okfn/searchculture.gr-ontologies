    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>An angular Arabic script; it is a formal type of Arabic calligraphy used decoratively on buildings, textiles, pottery and other things.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
