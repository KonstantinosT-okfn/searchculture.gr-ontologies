    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Methods of composing type in which characters are set by direct impression, as with typewriter composing machines.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
