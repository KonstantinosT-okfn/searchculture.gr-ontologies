    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The lifting of standard weights in a prescribed manner, as a competitive sport or a conditioning exercise. For the general use of weights as physical training or body toning, use "weight training."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
