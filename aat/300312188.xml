    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A compilation of coded instructions or sequence of code that, when run, achieves a certain task in a mechanism, usually a computer.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000099620/Legacy AAT data</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Een reeks gecodeerde instructies die door een apparaat of mechanisme, gewoonlijk een computer, kunnen worden uitgevoerd zodat ze een bepaalde taak uitvoeren.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
