    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ancient Greek votive images on plaques. The supports may be terracotta, wood, marble, or bronze; images may be cast, impressed, sculpted, or painted.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000046899/Clark, Elston and Hart, Understanding Greek Vases (2002)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
