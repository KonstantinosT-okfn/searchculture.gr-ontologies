    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Buildings, as prisons, hospitals, or libraries, so arranged that all parts of the interior are visible from a single point.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
