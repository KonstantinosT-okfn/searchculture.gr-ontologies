    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small bowls, usually of glass, for holding water to rinse fingers at the table.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
