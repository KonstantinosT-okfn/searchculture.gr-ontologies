    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A preliminary layer in a painting in which drawing, composition, and tonal values are worked out, or an area in one color which is then to be worked with glazes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000029111/Murray, Dictionary of Art and Artists (1971)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Een voorbereidende laag in een schilderij waarin tekening, compositie, en tonale waarden uitgewerkt worden, of een oppervlakte in één kleur die vervolgens wordt bewerkt met glazuurlagen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000113770/AAT-Ned (1994-)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000099099/Van Dale groot woordenboek (1994)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Eine vorbereitende Schicht bei einem Gemälde, in der Zeichnung, Komposition und Tonwerte herausgearbeitet werden, oder eine Fläche in einer Farbe, die dann mit Lasur bearbeitet wird.</Note_Text>
        <Note_Language>German</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000232/IfM-SMB-PK</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000122134/IfM Berlin</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
    </Descriptive_Notes>
