            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Nauwsluitende korte jasjes met korte panden, flappen of slippen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
