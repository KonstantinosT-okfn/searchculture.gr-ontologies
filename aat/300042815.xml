        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>organs (pipe organs) [300041686], aerophones [300041622], sound devices by acoustical characteristics [300041621], sound devices (equipment) [300387677], Sound Devices (hierarchy name) [300041619], Furnishings and Equipment (hierarchy name) [300264551], Objects Facet [300264092]</Parent_String>
