    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Instruments that measure and indicate the value of a quantity of something, as of gas, liquid, miles, or time.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
