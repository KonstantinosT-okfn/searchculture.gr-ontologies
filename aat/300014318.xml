    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A colorless or pale yellow bland and nearly odorless nondrying fatty oil used as an emollient.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
