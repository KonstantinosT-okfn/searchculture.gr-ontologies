    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Portable or fixed apparatuses that furnish heat for warmth or cooking, commonly using coal, oil, gas, wood, or electricity as a source of power.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000046682/Random House Dictionary of the English Language (1987)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Verplaatsbare of vaste apparaten die hitte leveren voor verwarming en/of om te koken, gewoonlijk door gebruik te maken van kolen, olie, gas, hout of elektriciteit.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
