    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tenors of orchestral oboes, having a pear-shaped bell with a small opening and its double reed carried on a short metal bocal.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
