    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Members of a group of people selected and sworn to decide upon matters of fact and  to declare the truth on the basis of the evidence presented before it in a court of law.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
