    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lenses set at one fixed distance from the film and offering no method of focusing adjustment; most common on inexpensive cameras.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000024531/Langford, Master Guide to Photography (1982)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Lenzen die op een vaste afstand van de film zijn gezet en waarbij het niet mogelijk is om de scherpstelling aan te passen; meestal aangebracht op goedkope camera's.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
