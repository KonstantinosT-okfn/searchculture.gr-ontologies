            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Úsese especialmente en referencia a la construcción de artículos hechos de madera.</Note_Text>
        <Note_Language>Spanish</Note_Language>
