  <Subject Subject_ID="300054114">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300229421</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>color changes [300229421], condition changing (processes) [300229410], processes and techniques by specific type [300053003], Processes and Techniques (hierarchy name) [300053001], Activities Facet [300264090]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
