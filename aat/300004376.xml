    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Women's quarters of Islamic houses. For the portions of Islamic houses reserved for men, use "selamliks."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
