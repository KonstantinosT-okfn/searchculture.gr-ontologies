    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A brown color of various hues, referring to the pigment raw umber and tending to be yellower than burnt umber.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
