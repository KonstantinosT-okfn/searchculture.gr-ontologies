            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Beeldende werken waarin gebruik wordt gemaakt van woorden en letters als formele elementen, vaak ongeacht de letterlijke betekenis. Geen goed Nederlands equivalent.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
