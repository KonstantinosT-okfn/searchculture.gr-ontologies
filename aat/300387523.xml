    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Areas of cities or towns that were the original centers of the historical settlements, particularly when the center of the current city is elsewhere. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000048302/Fleming, Penguin Dictionary of Architecture (1999)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Delen van steden die oorspronkelijk het centrum van de historische nederzetting waren, met name wanneer het centrum van de huidige stad ergens anders is.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
