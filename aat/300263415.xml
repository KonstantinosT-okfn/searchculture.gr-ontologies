    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Plates, usually metal, set in a coffin lid bearing the name of the deceased, usually with the dates of birth and death.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
