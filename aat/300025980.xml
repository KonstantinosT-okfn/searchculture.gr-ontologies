    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Groups of persons delegated to consider, investigate, or take action upon and usually to report concerning some matter or business.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
