              <Source_ID>2000079228/Grove Art Online (2008-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Con referencia a escritorios y mesas que presentan un arco centrado sobre el espacio donde se ubicarían el regazo y las rodillas de una persona.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
