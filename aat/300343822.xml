            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Opere eseguite dipingendo sul fronte o sul retro del vetro, anche con pigmenti vetrificati.</Note_Text>
        <Note_Language>Italian</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
