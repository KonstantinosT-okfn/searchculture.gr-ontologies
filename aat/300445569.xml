    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Hanging nose ornament in postclassic central Mexico. It could be worked in gold, decorated with stones or painted. Usually worn by slaves destined for sacrifice.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000320/GRI-FloCo</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
