    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A bronze alloy with a high lead content, the 80:10:10 mixture, making it a soft matrix metal ideal for use in bearings.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
