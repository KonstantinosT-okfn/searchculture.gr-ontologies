            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Wordt gebruikt voor tekeningen die meer zijn bedoeld als experimenten dan om te worden uitgevoerd, en die niet zo speculatief zijn als fantastische kunst of architectuur.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
