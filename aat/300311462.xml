    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Variable orange colors resembling the color of bricks, which are typically rectangular clay products used for building.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
