    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Motifs representing the head or skull of an ox, often garlanded, common in classical style friezes.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
