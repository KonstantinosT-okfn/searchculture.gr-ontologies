            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Smalle gordijnen die aan de zijkant van een opening worden vastgemaakt en alleen ter versiering dienen, omdat ze niet breed genoeg zijn om de tussenliggende ruimte te bedekken.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
