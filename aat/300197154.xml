    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small shallow cups sometimes with a convex domed center, used to hold a sample of wine being tasted.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
