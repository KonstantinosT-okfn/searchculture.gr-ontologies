    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Triple harps developed in Wales in the 17th century, having a slender forepillar of nearly two meters and a steeply curving neck, with a range normally of five octaves plus one note.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000030041/Sadie, New Grove Dictionary of Musical Instruments (1984)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
