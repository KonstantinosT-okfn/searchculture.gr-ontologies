      <Descriptive_Note>
        <Note_Text>Harpen met een slanke, bijna 2 meter lange voorzuil, sterk gebogen hals, toonbereik 5 octaven plus 1 prime; Wales, 17de eeuw.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
