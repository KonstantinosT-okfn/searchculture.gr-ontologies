  <Subject Subject_ID="300008180">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300008178</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>nature reserves [300008178], open spaces by function [300129929], open spaces [300008072], Open Spaces and Site Elements (hierarchy name ) [300139081], Built Environment (hierarchy name) [300264550], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
