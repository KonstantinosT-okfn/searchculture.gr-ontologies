    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Veils covering the body from head to foot, typically made of sheer black cotton or silk, and worn by Swahili women of Zanzibar, Pemba, and the coastal cities and towns of Tanzania and Kenya.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
