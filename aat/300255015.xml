        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Campo concerniente con el diseño y creación de sistemas agrícolas productivos de baja mantención y paisajes urbanos en que tienen la diversidad, estabilidad y resilencia de ecosistemas naturales.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
