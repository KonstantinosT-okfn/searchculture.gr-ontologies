    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Handmade powdered glass beads made in the Mauritanian town of Kiffa, decorated with molten colored glass in various colors.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
