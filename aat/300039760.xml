    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Relatively large side tables, some of which may have tops attached to the wall, which are used in a dining room for serving food or displaying dishes. For case furniture used to serve food and display, use "sideboards (furniture)."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
