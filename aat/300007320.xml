    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Descending troughs partially filled with constantly moving water through which people may ride or slide, usually terminating in a pool of water.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
