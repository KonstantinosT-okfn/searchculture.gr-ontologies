    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Cellulose, usually derived from wood pulp or cotton linter, that is treated with an alkali, such as sodium hydroxide; used to produce viscose rayon and other cellulose derivatives.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
