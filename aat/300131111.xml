        <Parent_String>positional attributes by relative position [300135444], positional attributes [300010269], attributes and properties by specific type [300226808], Attributes and Properties (hierarchy name) [300123559], Physical Attributes Facet [300264087]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
