    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Chairs with backs which may be lowered and seats that are hinged to unfold or that can otherwise be extended to form beds.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
