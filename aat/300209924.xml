    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Very short skirts that usually extend to mid-thigh. Also, similar components of a dress, coat, or the like.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
