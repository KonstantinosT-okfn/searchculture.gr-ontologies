    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Long shallow channels positioned under and paralleling the eaves of a building for the purpose of collecting and directing water from a roof.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
