    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The process of removing the outer layer of something, such as the removal of original paint when restoring a painting.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
