    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Transportation systems of attached vehicles, such as trains, that make is possible to move large numbers of people in the same travel corridor with greater efficiency.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
