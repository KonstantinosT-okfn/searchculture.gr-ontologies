    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Districts, including those originally possessing a degree of political independence or self-government, which have been incorporated into the boundaries of another administrative body.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
