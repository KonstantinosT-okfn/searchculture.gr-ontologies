    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The disciplines of philosophy, logic, and cognate subjects, particularly as included in the course of study for a degree in the ancient school of Literae Humaniores. Often seen as counterparts to the "arts."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
