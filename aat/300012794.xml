    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lumber whose edge is dressed and shaped for a tongue-and-groove joint when pieces are laid edge to edge or end to end.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
