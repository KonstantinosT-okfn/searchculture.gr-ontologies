    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tubes of wood or bamboo, often hollow, which are stamped rhythmically against the ground or another object.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
