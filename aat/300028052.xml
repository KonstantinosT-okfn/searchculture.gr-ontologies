    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Any materials representing, in whole or part, the earth or any celestial body at any scale.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
