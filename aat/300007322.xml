    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Quadrangular spaces either walled or otherwise marked off for playing one of various games usually with a ball.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
