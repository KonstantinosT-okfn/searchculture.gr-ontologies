        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>New Kingdom (Egyptian) [300020353], Egyptian periods [300020252], Egyptian (ancient) [300020251], Mediterranean (Early Western World) [300020058], Early Western World [300019255], styles, periods, and cultures by region [300111079], Styles and Periods (hierarchy name) [300015646], Styles and Periods Facet [300264088]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
