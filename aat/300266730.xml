    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Polymers created by combining two separate monomers from the vinyl group, vinyl acetate and vinyl chloride, for example.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
