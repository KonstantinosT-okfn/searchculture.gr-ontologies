    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Folds of definite, even width, made in a material such as textile or paper by doubling it upon itself; usually stitched, sometimes pressed in place.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
