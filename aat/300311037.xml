    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Modifier describing a color of light intensity and light value; may be overlapping in meaning with the modifier "pale."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
