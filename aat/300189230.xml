        <Parent_String>behavior disorders [300189155], behavior and mental disorders [300189628], psychological concepts [300055148], social science concepts [300239103], Associated Concepts (hierarchy name) [300055126], Associated Concepts Facet [300264086]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
