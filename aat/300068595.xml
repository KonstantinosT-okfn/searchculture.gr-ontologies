    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The development and use of sustainable approaches to meeting human and ecological needs through the applications of scientific principles and engineering techniques as they are connected to the place, resources, economics, culture and impacts of their uses.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
