    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Cultivating implements used primarily for pulverizing or smoothing the soil, sometimes for mulching, covering seed, or removing weeds.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
