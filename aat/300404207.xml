    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Literary works in the form of poetry that tells a story, often making use of the voices of a narrator and characters as well. The story may be written in metered verse, but not necessarily following rhythmic patterns. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
