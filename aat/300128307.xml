        <Parent_String>olive colors [300311122], chromatic colors [300131648], colors (hues or tints) [300080438], Color (hierarchy name) [300131647], Physical Attributes Facet [300264087]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
