    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Marketplaces, usually consisting of a network of covered streets, stalls, booths, and shops, common in parts of North Africa and West Asia.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
