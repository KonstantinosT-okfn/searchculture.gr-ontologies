    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Extensions attached to a compass to extend the length of one of the legs; used to increase the radius of an inscribed arc or circle.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
