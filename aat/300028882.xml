    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Depiction or description of sexual love. For depiction or description of sexual activity in an explicit manner intended to stimulate erotic rather than aesthetic feeling, use "pornography."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
