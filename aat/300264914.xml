    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A type of continuous curve amphorae characterized by a convex or echinus shaped lip, and a torus or echinus foot.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000046786/Getty Museum, Authority file (2003-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Een soort volkomen geronde amforen die zich kenmerken door een bolle echinusvormige lip en een torus- of echinusvoet.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
