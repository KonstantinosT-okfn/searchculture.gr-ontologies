        <Parent_String>pistols by function [300203847], pistols [300037160], handguns (small arms) [300037158], small arms by form [300037156], small arms [300037150], firearms [300037148], projectile weapons with explosive propellant [300208782], projectile weapons [300203727], armaments [300420324], weapons [300036926], Weapons and Ammunition (hierarchy name) [300036743], Furnishings and Equipment (hierarchy name) [300264551], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
