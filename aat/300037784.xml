    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Armchairs with adjustable backs and loose cushions, of a type first produced by William Morris, Philip Webb, and the firm Morris, Marshall, Faulkner and Co. about 1866 in England.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
