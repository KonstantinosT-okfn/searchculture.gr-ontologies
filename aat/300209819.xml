    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Suits for small boys consisting of a shirt and shorts made of matching or coordinating fabric and held together by buttons at the waist.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
