    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to the periods and styles in Europe from the Migration period to the Romanesque period, roughly covering the fourth to the eleventh centuries.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
