    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Aldehyde tanning done by exposing leather to smoke, which contains aldehydes. Usually done in combination with oil tanning.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
