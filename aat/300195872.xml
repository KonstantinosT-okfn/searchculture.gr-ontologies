    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Mechanical pressure-measuring instruments employing as sensing elements a curved or twisted metal tube, flattened in cross-section and closed.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
