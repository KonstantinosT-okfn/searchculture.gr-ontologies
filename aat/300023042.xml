    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Chunky hammers with two striking surfaces covered with rows of pyramidal metal teeth or points; used in stone carving.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000026701/Mayer, Dictionary of Art Terms and Techniques (1969)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Ruwe hamers met twee slagvlakken die zijn uitgerust met een rij piramidevormige, metalen tanden of punten. Worden gebruikt bij steenhouwen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
