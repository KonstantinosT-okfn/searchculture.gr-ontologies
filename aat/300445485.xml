    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Those employed in the use of crossbows, either as a member of a military unit or as an activity related to combat or hunting.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000320/GRI-FloCo</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
