    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Persons who compose text for opera, musical plays, or extended choral works, or who adapt text to accommodate the musical requirements of composers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
