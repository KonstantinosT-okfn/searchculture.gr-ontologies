        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>Sub-Saharan African Second Intermediate Stone Age periods [300015682], prehistoric Sub-Saharan African periods [300015667], prehistoric African [300015649], African (general, continental cultures) [300015647], styles, periods, and cultures by region [300111079], Styles and Periods (hierarchy name) [300015646], Styles and Periods Facet [300264088]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
