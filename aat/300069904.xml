    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Roofs in which the slope is broken, the lower slope being steeper than the upper slope; may be two-sided or four-sided roofs.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
