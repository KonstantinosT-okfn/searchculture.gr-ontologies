    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Prints that have been mounted on glass, the paper rubbed away, and color applied to the back; popular in the late 17th and early 18th centuries.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
