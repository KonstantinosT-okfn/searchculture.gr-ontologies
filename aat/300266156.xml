      <Descriptive_Note>
        <Note_Text>Verwijst naar hindoetempelcomplexen bestaande uit één hoofdtempel omgeven door vier kleinere heiligdommen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
