        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Barniz espirituoso de resina mezclado con alcohol que produce una terminación suave y un excelente pulido, aunque no enteramente repelente del agua.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
