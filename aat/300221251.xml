    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to those derringers actually made by Henry Deringer, the Philadelphia gunsmith who first developed the type.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
