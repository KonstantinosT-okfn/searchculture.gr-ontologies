    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Bridges used by the military; particularly those used in wartime, such as portable pontoon bridges used to cross rivers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
