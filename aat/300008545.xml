    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Artificial mounds consisting of the accumulation of debris from successive settlement levels; common in regions where mud brick is used.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
