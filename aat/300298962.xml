        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Una struttura pieghevole di piccole dimensioni a forma di baldacchino.</Note_Text>
        <Note_Language>Italian</Note_Language>
        <Note_Contributors>
