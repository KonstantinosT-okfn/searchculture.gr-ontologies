    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Shoelike devices or platforms that attach to shoes, are fitted with a metal blade or blades, and are used for gliding across ice.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
