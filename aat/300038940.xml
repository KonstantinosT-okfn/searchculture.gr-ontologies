    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>French 17th- and 18th-century cabinets on stands used to store jewels; often heavily adorned with inlay.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
