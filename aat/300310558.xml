    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Family containing several hundred species of small, conical-billed, seed-eating songbirds, including many, but not all, called "finches."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
