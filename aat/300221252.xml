    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Low, flat utensils having short legs, upon which to rest a teapot in order to protect the surface below from the heat.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
