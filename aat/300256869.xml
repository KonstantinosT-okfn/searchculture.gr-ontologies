    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small self-contained systems with a platform that rises vertically, usually only one story or less, to transport a wheelchair or merchandise.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
