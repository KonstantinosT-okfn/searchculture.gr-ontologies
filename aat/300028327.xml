    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Nautical charts used for navigation close to shore, such as for entering or leaving bays and harbors or for navigating inland waterways.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
