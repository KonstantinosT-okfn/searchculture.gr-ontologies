    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Elements that serve to stiffen or stabilize a member or a structure, long in relation to their width and usually set on a diagonal.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
