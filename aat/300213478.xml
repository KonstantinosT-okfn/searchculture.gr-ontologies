            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000052381/Van Dale Engels-Nederlands (1989)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
    </Descriptive_Notes>
