            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Exenciones o provisiones especiales para negocios tales como asignación de devaluación acelerada, créditos y deducciones, con la intención de promover social o económicamente actividades provechosas.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
