    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Chinese site analysis method that employs geomantic techniques; used especially in determining the placement and design of houses, graves, and gardens.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
