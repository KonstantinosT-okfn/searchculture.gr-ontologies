            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000113770/AAT-Ned (1994-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Afvalzijde; gesponnen van de restvezels bij het maken van het iets hoogwaardigere chappezijde. De vezels hebben een lengte van 3-5 cm. Glanst minder dan het ongesponnen filament van de cocon.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
