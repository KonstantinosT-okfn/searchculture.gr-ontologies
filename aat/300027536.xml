    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Surety bonds executed by the bidder on a construction project that serve as a guarantee that the bidder will enter into a contract within a specified time and furnish any required bonds ensuring completion of the work.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
