    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Objects relating to Jewish life, religion, and culture, especially but not limited to those of a literary, historic, or artistic nature, or pertaining to ritual. For individual types of items, see appropriate hierarchies.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
