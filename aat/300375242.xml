    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Objects used to warm a bed. Traditionally refers to a covered pan with an extended handle filled with hot coals.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
