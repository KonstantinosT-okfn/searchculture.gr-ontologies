    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Buildings that house universities located in and serving urban communities, although not necessarily maintained by municipalities.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
