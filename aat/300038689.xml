      <Descriptive_Note>
        <Note_Text>Dik opgevulde, beklede sofa's waarvan het houtwerk niet zichtbaar is.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
