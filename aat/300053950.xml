            <Source>
              <Source_ID>2000121670/Guidelines for the Technical Examination of Bronze Sculpture (2025)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
    </Descriptive_Notes>
