    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Drinking glasses of apparently normal but actually minute capacity originally used by 18th-century toastmasters.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
