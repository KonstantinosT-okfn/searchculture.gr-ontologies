    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Full-length or three-quarter-length overcoats, usually made of fine fabrics, worn for formal or semiformal occasions; popular especially during the early 20th century.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
