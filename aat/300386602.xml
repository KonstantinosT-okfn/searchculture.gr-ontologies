    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Color rendering that replaces normal, human- percievable color with assigned colors to highlight the visual display of phenomena, or to enhance contrasts.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
