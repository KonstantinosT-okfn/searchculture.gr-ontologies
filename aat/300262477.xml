    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Style and culture of the African ethnic group of the same name living primarily in southwestern Chad, with smaller numbers in Cameroon.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
