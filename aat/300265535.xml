    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Arabic script possibly invented by calligrapher Ibn Muqlah in the 9th century CE, and based on the thuluth script.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
