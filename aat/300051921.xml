            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Gewindemutter, die zum Ausrichten eines Objekts verwendet wird und oft mit einer Kontermutter verbunden ist, um sie in der Position zu sichern.</Note_Text>
        <Note_Language>German</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000232/IfM-SMB-PK</Contributor_id>
