            <Source>
              <Source_ID>2000113770/AAT-Ned (1994-)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000052386/Linden, grafische technieken (1970)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Bild, das durch Auflegen von Papier oder Stoff auf eine reliefartige, eingeritze oder strukturierte Fläche und dem anschließenden Durchreiben erzeugt wird.</Note_Text>
        <Note_Language>German</Note_Language>
