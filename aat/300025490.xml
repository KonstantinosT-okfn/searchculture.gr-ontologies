    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Archaeologists who specialize in studying the sites, structures, and artifacts of the industries and processes of industrialization of former times.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
