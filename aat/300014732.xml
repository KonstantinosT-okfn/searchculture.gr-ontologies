    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Material, often a compound of lead, iron, manganese, or cobalt, used for increasing the rapidity of the drying of paint and varnish.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
