    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Naturally occuring groups of plants that share a common environment and interact with each other, animal populations, and the physical environment. Plant communities tend to co-occur on the landscape due to shared environmental requirements.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
