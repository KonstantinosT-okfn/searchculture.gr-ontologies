    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small pyramid or cone shaped made from various refractory materials and intended to melt at different temperatures; used in kilns where temperature is not automatically regulated.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
