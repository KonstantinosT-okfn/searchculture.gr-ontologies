        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>lightweight construction [300111593], construction technique by form or materials [300101671], construction (built works technique) [300054608], assembling (additive and joining process) [300053007], additive and joining processes and techniques [300229467], processes and techniques by specific type [300053003], Processes and Techniques (hierarchy name) [300053001], Activities Facet [300264090]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
