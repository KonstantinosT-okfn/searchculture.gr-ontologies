    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Government-authorized adhesive stamps, imprinted stamps, hand stamps, or meter markings issued as evidence of prepayment of postage.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
