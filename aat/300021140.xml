        <Parent_String>Renaissance-Baroque styles and periods [300021031], European [300020656], styles, periods, and cultures by region [300111079], Styles and Periods (hierarchy name) [300015646], Styles and Periods Facet [300264088]</Parent_String>
        <Parent_Date>
          <Display_Date>in Italy in the late 14th century, spread throughout Europe, and culminated in the 16th century</Display_Date>
          <Start_Date>1380</Start_Date>
          <End_Date>1600</End_Date>
        </Parent_Date>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
