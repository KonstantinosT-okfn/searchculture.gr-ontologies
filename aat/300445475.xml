    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Prickly pear cactus, also called Barbary fig (Opuntia ficus-indica).</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
