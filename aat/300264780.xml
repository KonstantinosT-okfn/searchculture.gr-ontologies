    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Abstract sculptures without moving parts, as oppose to a mobile. The term was coined in 1931 by Jean Arp to describe the stationary work of the artist Alexander Calder.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
