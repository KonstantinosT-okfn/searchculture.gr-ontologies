            <Source>
              <Source_ID>2000051034/TAA database (2000-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Hulzen van metaal, plastic of vezels geplaatst in een gat in metselwerk, gips of beton, die uitzetten wanneer de schroef erin wordt gedraaid.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
