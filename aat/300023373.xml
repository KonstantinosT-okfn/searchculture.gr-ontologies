    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Wrenches which consist of a steel bar, hexagonal in section, bent to form a right angle; used for Allen screws.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
