              <Source_ID>2000114707/Oxford English Dictionary Online (2002-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Úsese con referencia a los roperos de estilo francés para guardar ropa o lencería.</Note_Text>
        <Note_Language>Spanish</Note_Language>
