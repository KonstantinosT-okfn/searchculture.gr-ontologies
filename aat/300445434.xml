    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>In Mexico, any food taken on a journey, and otherwise given or brought to be consumed away from one's house.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000320/GRI-FloCo</Contributor_id>
