    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Dishes of varying forms and materials used for serving sweetmeats; includes those suspended from the arms of sweetmeat stands. For stemmed dessert glasses used for serving sweetmeats, use "sweetmeat glasses."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
