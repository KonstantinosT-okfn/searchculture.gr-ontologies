        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Armas de asta francesas e inglesas usadas entre los siglos XII y XIV, que tenían una cabeza puntiaguda con una hoja parecida a una guadaña y un filo triangular en el dorso.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
