    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Zinc sulfide coprecipitated with barium sulfate; it is used as a dense white pigment in house paint and industrial coatings.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
