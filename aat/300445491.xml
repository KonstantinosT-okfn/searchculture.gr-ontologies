    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A market in postclassic central Mexico. Place where the pochtecah (merchants) converged. Still used today to refer to several different types of shopping places.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000320/GRI-FloCo</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
