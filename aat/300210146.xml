    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>An Insular script of angular, compressed, minuscule form, with pronounced pointed descenders, often incorporating cursive elements.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000099620/Legacy AAT data</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Een insulair schrift met een hoekige, ingedikte, minuscule vorm, met geprononceerd gepunte staartletters, dat vaak cursieve elementen bevat.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
