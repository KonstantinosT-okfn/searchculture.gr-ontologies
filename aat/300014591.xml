      <Descriptive_Note>
        <Note_Text>Bewerkte of verwerkte bijenwas die werd gebruikt bij oude encaustische schilderijen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
