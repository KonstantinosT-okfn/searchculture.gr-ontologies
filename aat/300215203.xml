            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Cubiertas de lino grandes usadas para cubrir la baranda del altar durante el oficio de la comunión.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
