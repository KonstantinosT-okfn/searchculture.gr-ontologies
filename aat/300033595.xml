    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Keys adapted for use with a mortise lock and a cup escutcheon on sliding doors; its length is usually adjustable.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
