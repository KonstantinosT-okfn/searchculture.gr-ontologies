        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Een compact marmer dat te vinden is in de graafschappen Galway en Kilkenny in Ierland en dat wordt beschouwd als een van de beste zwarte marmers.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
