    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Fortified log structures with loopholes or ports in their sides which permit gunfire in all directions.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
