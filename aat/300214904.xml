    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Pipes which are constituent parts of other aerophones, have fingerholes, and are used to play the melody.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
