    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Parts of building plumbing systems that carry away waste; for sewers designed to carry away waste in larger drainage systems, use "sanitary sewers."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
