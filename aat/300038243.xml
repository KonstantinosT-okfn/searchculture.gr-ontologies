    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Chairs mounted on wheels that may either be pushed or propelled by the occupant by means of hand rims attached to the two large side wheels.</Note_Text>
        <Note_Language>English</Note_Language>
