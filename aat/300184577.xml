    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ancient Greek sculptures in which the extremities are made of stone and the torso is made of another material, usually wood.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
