  <Subject Subject_ID="300133025">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300234076</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>object genres by cultural or intellectual evaluation [300234076], object genres (object classifications) [300185712], Object Genres (hierarchy name) [300185711], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
