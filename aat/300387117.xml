    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Territories, usually non-self-governing, that lie outside the borders of the nation to which they are bound, but typically not so distant as overseas territories</Note_Text>
        <Note_Language>English</Note_Language>
