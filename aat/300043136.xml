    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Large ladles intended primarily for conveying punch or other beverages from punch bowls to punch cups; similar to soup ladles but generally having a longer and narrower handle and a smaller, lipped bowl.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
