    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>An ornamental black marble found in fragments among Roman ruins and believed to have come from Laconia.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
