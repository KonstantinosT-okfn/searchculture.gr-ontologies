    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Beads that are created from natural shells, usually having a hole drilled in the shell to allow stringing. May also include beads having shells as a material, carved or ground down so as to not resemble shells when completed.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
