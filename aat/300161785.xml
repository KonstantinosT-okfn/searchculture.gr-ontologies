    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tongs primarily used by clock- and watchmakers to hold pins, arbors, or other small objects while they are being filed.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
