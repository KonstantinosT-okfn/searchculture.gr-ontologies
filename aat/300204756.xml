    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tapestry-woven Navajo pictorial rugs depicting yeibichai, Navajo dancers impersonating the yei, or Holy People.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
