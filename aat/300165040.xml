  <Subject Subject_ID="300165040">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300191091</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>visual works by material or technique [300191091], visual works (works) [300191086], Visual Works (hierarchy name) [300179869], Visual and Verbal Communication (hierarchy name) [300264552], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
