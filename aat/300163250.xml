    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A type of portland cement whose chemical composition has been altered so that little heat is produced during hardening.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
