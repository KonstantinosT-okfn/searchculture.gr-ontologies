    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small holes, usually near the base of a container, through which liquid can be poured; usually found in rundlets and water coolers.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
