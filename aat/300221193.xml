    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Open, usually cylindrical containers used to hold cigarettes on a table, desk, or the like. For covered boxes used to hold cigarettes, use "cigarette boxes."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
