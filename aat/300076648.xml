    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ceilings formed by or suggesting open-timbered roofs, often higher than the ceilings of the other rooms in the building.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
