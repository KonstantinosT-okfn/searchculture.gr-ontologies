    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ancient sacred areas, usually enclosed and containing the principal shrine and other associated subsidiary buildings.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
