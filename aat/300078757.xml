    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Forms or outlines delimited by lines defining a sector equal to one quarter of a circle or half a semicircle, having an arc of 90 degrees.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
