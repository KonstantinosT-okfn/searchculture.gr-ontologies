    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Emotional and psychological state generated from the resentment and awareness of an advantage enjoyed by another joined with the desire to possess the same advantage.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
