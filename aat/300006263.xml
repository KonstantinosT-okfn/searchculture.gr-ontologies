    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>High towers, usually round, in which shot is made by dropping molten lead from an upper story into a cistern of water.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
