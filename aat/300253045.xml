    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lyric poems of exalted emotion devoted to the praise or celebration of its subject; often employing complex or irregular metrical form.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
