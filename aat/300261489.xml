    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The process of attaching boards to a text block by passing the bands or cords on which the text block is sewn through holes cut into the boards.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
