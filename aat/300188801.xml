            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Wordt gebruikt voor nieuwbouwprojecten waarbij particulieren, families of coöperaties worden voorzien van eigendomsrecht en verbeterde grond waarop gebouwen, meestal huizen, kunnen worden gebouwd.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
