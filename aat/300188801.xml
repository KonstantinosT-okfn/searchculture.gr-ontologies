    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Self-help development practices where individuals, families, or cooperatives are provided with title and improved land on which buildings, usually housing, can be built.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
