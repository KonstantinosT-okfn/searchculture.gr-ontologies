    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Those contracts in which a builder agrees to complete the work of building and installation to the point of readiness for occupancy.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
