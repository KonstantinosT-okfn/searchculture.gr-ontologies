    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Sets or group of initial letters used as an abbreviation for a name or expression, for which each letter is pronounced separately. For initials pronounced as syllables or single word, use "acronyms."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
