    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Fortifications that incorporate enclosed earthworks with bastions (projecting portions) at the angles where the curtain walls meet. They are designed to provide coverage by defensive weapons, which are able to fire from the projecting portions along the fronts of the curtain walls.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000062666/Robinson, Military Architecture at Mobile Bay (1971)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>s. &lt;a href="http://books.google.de/books?id=D5O2ph_d9-wC&amp;pg=PA376&amp;lpg=PA376&amp;dq=%22bastioniertes+fort%22&amp;source=bl&amp;ots=XOrEM0TUwk&amp;sig=4QGj3HWDQQQTn0KCcfQSZk4qiis&amp;hl=de&amp;sa=X&amp;ei=STtDUfr3BoTltQaj64CwAg&amp;ved=0CD8Q6AEwAg#v=onepage&amp;q=%22bastioniertes%20fort%22&amp;f=false" target="blank"&gt;Glossarium Artis: Festungen&lt;/a&gt;</Note_Text>
