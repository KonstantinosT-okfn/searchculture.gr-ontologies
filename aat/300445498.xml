    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Nahuatl term referring to the upper part of the human body, including the upper limbs, head and torso.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
