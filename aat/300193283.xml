    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>English silver coins originally worth four pennies and issued between the 13th and 17th centuries, and occasionally later.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
