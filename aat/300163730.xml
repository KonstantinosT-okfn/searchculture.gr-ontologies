    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Describes buildings, particularly classic Greek and Roman temples and buildings like them in structure, having ten columns at one or both ends.</Note_Text>
        <Note_Language>English</Note_Language>
