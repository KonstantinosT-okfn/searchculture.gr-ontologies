    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Human behavior as an external manifestation of displeasure or sorrow, displayed as a sobbing sound usually accompanied by tears. Animal's ability to make a particular cry specific to their species.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
