    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Places on the back of a text block where the sewing needle emerges from or passes into the leaves or gatherings, generally designated during marking up.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
