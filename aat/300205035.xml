    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Type of bottle that preceded the decanter and was used to bring wine to the table from the cask; made in a variety of forms and materials such as stoneware, delftware, and glass.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
