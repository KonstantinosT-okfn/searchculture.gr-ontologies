            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Het klimaat dat wordt gekenmerkt door hoge temperaturen en zware neerslag die gedurende het hele jaar valt of wordt afgewisseld met droge seizoenen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
