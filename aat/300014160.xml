    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Slightly translucent paper with a smooth finish suitable for a variety of media, used in advertising layout or other industries such as design or architecture, or more specifically: sheets of paper ruled horizontally and vertically in picas.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000024401/Labarre, Dictionary and Encyclopaedia of Paper (1952)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000052009/Snyder, Commercial Artist's Handbook (1973)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>略呈半透明的紙張，表面平滑，可搭配應用多種媒材，用於廣告版面設計或其他如設計、建築等領域，亦專指繪有以匹卡(pica，1/6英吋)為單位之水平與垂直格線的紙張。</Note_Text>
        <Note_Language>Chinese (traditional)</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000250/AS-Academia Sinica</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
      </Descriptive_Note>
    </Descriptive_Notes>
