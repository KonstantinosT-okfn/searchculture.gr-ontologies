        <Parent_String>housed joints [300045399], wood joints [300033611], joints by material joined [300048693], joints (connections) [300033608], joints and joint components [300387687], components by general context [300241581], components (objects parts) [300241583], Components (hierarchy name) [300241490], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
