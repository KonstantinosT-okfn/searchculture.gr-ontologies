    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Functional or ornamental bands of flexible material sewn or adhered to the back of a book's text block at head and tail, projecting slightly above and below the text block.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
