        <Parent_String>sundials [300041614], timepieces by form [300196327], timepieces [300041573], measuring devices for extent [300195701], measuring devices (instruments) [300207870], Measuring Devices (hierarchy name) [300207851], Furnishings and Equipment (hierarchy name) [300264551], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
