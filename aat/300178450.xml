    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Layers in a painting, usually an oil painting, that are between the ground or primer and any protective coating.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000009721/Constable, Painter's Workshop (1954)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Wordt gebruikt voor de lagen in een schilderij, gewoonlijk in een olieverf schilderij, die zich tussen de grond- of verflaag en een eventuele beschermlaag bevindt.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
