    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lesions on the skin such as pustules or blisters. It is a term that is often translated as smallpox because it was a term used by Nahuatl writers to describe certain epidemic diseases.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000320/GRI-FloCo</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
