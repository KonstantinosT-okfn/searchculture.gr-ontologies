    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>One-piece garments worn by parachutists for jumping.  Also, similar garments combining a shirt or bodice with trousers or shorts in one piece.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
