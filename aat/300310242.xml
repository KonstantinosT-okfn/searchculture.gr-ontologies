    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Phylum of 15 species of predatory, marine, mud-inhabiting, unsegmented worms. They are sometimes classified as a class.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
