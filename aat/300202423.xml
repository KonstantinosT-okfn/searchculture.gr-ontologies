    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Signs or notices, usually of stiff paper or cardboard, posted in public or carried in public, for example by picketers or demonstrators.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
