    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Folding, umbrellalike fabric devices with cords supporting a harness or straps for allowing objects to float down safely through the air.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
