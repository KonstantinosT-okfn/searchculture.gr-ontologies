    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Devices for measuring either the quantity of alkali in a solid or liquid or the quantity of carbon dioxide formed in a reaction.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
