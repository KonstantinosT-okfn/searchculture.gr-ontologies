            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Tragbares, relativ kleines Gemälde, insbesondere im Unterschied zu  Wandmalerei oder Buchmalerei.</Note_Text>
        <Note_Language>German</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
