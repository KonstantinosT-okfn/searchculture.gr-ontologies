    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lamps formed from drinking glasses by the addition of pierced, domed covers and carrying handles and the insertion of a lamp or candleholder.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
