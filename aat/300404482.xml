    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Gaulish Coligny calendar used by Celtic countries to define the beginning and length of the day, the week, the month, the seasons, quarter days, and festivals.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
