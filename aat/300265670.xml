        <Parent_String>cooling, heating and humidifying components [300052135], HVAC components [300052683], system components [300242031], components by specific context [300241584], components (objects parts) [300241583], Components (hierarchy name) [300241490], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
      </Preferred_Parent>
