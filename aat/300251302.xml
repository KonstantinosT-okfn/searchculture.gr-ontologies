    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lighting devices where the housing is set above the ceiling, and the lamp lens is flush or nearly flush with the ceiling.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
