    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Long sticks with a pair of footrests about 1 foot from the bottom attached to a powerful spring at the bottom and used for standing on and leaping.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
