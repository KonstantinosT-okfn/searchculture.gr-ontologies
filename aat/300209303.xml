    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Pins used to fasten garments, resembling a large safety pin with an enlarged catch plate; often elaborately ornamented.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
