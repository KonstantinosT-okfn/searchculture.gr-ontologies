    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Plan of a building or city that is arranged within a hexagon (six sides of equal length), usually a centralized plan.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
