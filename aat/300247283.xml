    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Study of medical concepts and practice throughout human history in a global, social, cultural, and scientific context including theories, diseases, health care, individual practitioners, special branches of medicine, and medical professions such as nursing.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
