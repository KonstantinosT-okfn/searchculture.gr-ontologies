    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Instruments that record the duration of sunshine and provide qualitative measurements of the amount of sunshine by the action of the sun's rays on blueprint paper.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
