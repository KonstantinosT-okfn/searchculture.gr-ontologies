    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small gifts given as a token of favor or goodwill; also amusing or decorative items given to those attending celebrations or parties.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
