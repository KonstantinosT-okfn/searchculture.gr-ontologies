        <Parent_String>rulers (people) [300025475], people in administration and government [300025426], people by occupation [300024980], people (agents) [300024979], People (hierarchy name) [300024978], Agents Facet [300264089]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
