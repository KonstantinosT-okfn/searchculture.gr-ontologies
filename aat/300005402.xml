    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Broadcasting stations for sending and receiving radio programming transmissions; for rooms and spaces designed for the origination or recording of radio programs, use "radio studios."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
