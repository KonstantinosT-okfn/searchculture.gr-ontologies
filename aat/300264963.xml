    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to a type of oinochoe similar to shape 2 and featuring a round mouth (also called a flat mouth).</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
