    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Plates, usually of metal, placed on doors, usually of houses, apartments, or rooms, bearing the occupant's name or other identifiers.</Note_Text>
        <Note_Language>English</Note_Language>
