    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Practitioners of the general management of urban areas, encompassing the setting of objectives for urban life, the establishment of policies, and the planning, development, operation, and maintenance of the urban environment and services.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
