    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A unit of measure for information or computer storage representing 1024 or 1000 bytes. The most commonly referred to unit of computer file size.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
