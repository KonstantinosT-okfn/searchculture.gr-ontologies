            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Meeteenheid voor opgeslagen informatie op een computer ter grootte van 1024 of 1000 bytes. De meest gebruikte eenheid om de grootte van computerbestanden uit te drukken.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
