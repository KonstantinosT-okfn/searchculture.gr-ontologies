    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Those versed in the study of the theistic philosophy that views creative becoming as the universal form of reality and emphasizes the relational nature of all being. </Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
