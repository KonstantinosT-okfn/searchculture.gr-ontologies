    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to the rolls, faced at either end with volutes, forming the sides of an Ionic capital.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
