    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Road arrangements, resembling four-leaf clovers in plan, for permitting easy traffic movement between intersecting highways.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
