    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>In masonry or stonework, joints which employ joggles in the adjacent members so as to prevent their later movement.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
