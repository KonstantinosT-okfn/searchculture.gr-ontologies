    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Crosses with an X or several crossed lines placed over the point where the two bars of the cross intersect, symbolizing rays of light or a star.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
