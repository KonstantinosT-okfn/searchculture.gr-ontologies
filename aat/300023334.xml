    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Tools for joining metals with solder, having a wedge-shaped metal bit, usually of copper, which is heated.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
