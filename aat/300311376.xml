    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to a range of yellowish green colors, the name coming from the common Irish name "Kelly," referring to the association of Ireland with the color green.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
