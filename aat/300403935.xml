    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Finnish variations of Jugend and Art Nouveau, including elements of Finnish nature and national culture, such as folk poetry, folk life, mediaval Finnish ecclesiastical architecture, Carelian folk, architecture, among others.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
