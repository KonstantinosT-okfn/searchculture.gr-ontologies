    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Decorated miters, lacking jewels, worn by Christian officiates. For miters decorated with gold and jewels, use "mitra pretiosa." For miters of simpler materials, use "mitrae simplex."</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000050867/Catholic Encyclopedia online (1997-2003)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000027131/Mayo, History of Ecclesiastical Dress (1984)</Source_ID>
            </Source>
          </Note_Source>
          <Note_Source>
            <Source>
              <Source_ID>2000093795/Encyclopedia Britannica Online (2002-)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Versierde mijters, maar zonder juwelen, die door voorgangers in de rooms-katholieke kerk worden gedragen. Gebruik 'mitra pretiosa' voor mijters die zijn versierd met goud en juwelen. Gebruik 'mitra simplex' voor mijters zonder versiering.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
