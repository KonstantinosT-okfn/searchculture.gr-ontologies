    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Ancient projectile launchers used by the Imperial Romans, built like large crossbows and used to hurl javelins, large rocks, and other large projectiles.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
