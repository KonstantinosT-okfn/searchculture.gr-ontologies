    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lightly armored, highly mobile, fully tracked vehicles primarily for transporting personnel on and off the battlefield; usually fitted with light armament.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
