    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Secondary nuts used on a bolt to prevent the first nut from turning; also nuts which lock when tightened.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
