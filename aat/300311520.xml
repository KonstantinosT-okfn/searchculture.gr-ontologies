    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A range of yellow colors resembling the color of barium yellow pigment, made from barium chromate.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
