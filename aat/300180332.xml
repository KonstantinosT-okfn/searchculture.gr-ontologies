    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Lighting devices which emit strong directional light. Often used in photography and filmmaking to illuminate the subject.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
