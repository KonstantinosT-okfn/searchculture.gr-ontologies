    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Generic term for various types of space-saving tables with leaves hinged to the top so that they can be raised to extend the surface.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
