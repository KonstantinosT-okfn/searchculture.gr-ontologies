    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Rugs made of mats measuring about 2 feet square that have been sewn together; often placed between pillars in Buddhist temples.</Note_Text>
        <Note_Language>English</Note_Language>
