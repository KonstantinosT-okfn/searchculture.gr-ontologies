    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Continental European noblemen holding a countship, ranking on the same level as British earls, below dukes and marquises and above viscounts.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
