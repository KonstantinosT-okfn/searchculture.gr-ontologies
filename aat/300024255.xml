    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Plier-like tools which set the teeth of a saw after they have been sharpened. They may be adjusted for use on different saws.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000005711/Blackburn, Illustrated Encyclopedia of Woodworking Handtools (1974)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Buigtangachtig gereedschap waarmee de tanden van een zaag kunnenn worden gezet nadat ze zijn geslepen. Ze kunnen worden aangepast om op verschillende zagen te gebruiken.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
