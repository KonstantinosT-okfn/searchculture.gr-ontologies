    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Long, narrow textiles used as furniture coverings, to protect polished surfaces and as decoration. Shorter and narrower than scarves for furniture.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
