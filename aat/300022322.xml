    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Mobile loaders that use a series of small buckets on a roller chain to elevate excavated dirt or rock to the dumping point.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000038881/Stein, Construction Glossary (1980)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Cargador móvil que usa una serie de cubetas pequeñas sobre una cadena cilíndrica para elevar lodo o rocas excavadas a un punto de descarga.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
