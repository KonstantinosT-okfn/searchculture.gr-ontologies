            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Verplaatsbare laadbanden die gebruik maken van een rij kleine emmers aan een rolketting om afgegraven aarde of stenen naar de dumpplaats te brengen.</Note_Text>
        <Note_Language>Dutch</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000205/AAT-Ned</Contributor_id>
