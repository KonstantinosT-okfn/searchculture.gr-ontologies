    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Refers to the period at the beginning of the 2nd millennium BCE in Mesopotamia during which the city of Mari rose to prominence.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
