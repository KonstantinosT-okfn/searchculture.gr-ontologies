    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Health sciences discipline that uses gardens, plants, and horticultural activities to promote improvement in the physical and psychological well-being of patients.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
