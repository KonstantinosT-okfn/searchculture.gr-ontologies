    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Woven textile material characterized by a weave structure that uses a secondary or binding warp to bind the wefts that form the design, producing a double weave effect.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
