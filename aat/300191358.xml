    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Use both for bronze coins of the Roman Republic and for copper coins used during the Roman Empire from the 1st century BCE through the 3rd century CE.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
