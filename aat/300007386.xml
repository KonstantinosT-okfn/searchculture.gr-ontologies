    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Steeply inclined, snow-covered courses with a horizontal take-off at the end from which skiers glide off into the air.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
