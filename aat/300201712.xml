        <Parent_String>shells (ammunition) [300204078], armament shells [300420320], ammunition for artillery [300204066], ammunition [300036928], Weapons and Ammunition (hierarchy name) [300036743], Furnishings and Equipment (hierarchy name) [300264551], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
      </Preferred_Parent>
