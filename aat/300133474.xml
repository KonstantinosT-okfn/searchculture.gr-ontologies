            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>Proceso sustractivo de color que utiliza un proceso de blanqueo de colorantes para realizar impresiones fotográficas. Utilizado también en cinematografía.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
