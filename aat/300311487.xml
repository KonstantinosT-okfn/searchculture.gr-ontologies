    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>A class of dark blue and black dyes made by the oxidation of aniline, used dying textiles, wood, leather, fur, inks, shoe polishes, and paints.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
