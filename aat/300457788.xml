    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Art objects acquired unjustly or without sanction. This may include objects stolen, confiscated, sold by force, exchanged or renounced during armed conflicts, revolutions or in a colonial context.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
          <Note_Contributor>
