    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Style and culture of the African ethnic group of the same name inhabiting the border area of Kenya and Uganda, north of Lake Victoria.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
