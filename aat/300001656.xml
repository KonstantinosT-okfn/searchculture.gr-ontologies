  <Subject Subject_ID="300001656">
    <Parent_Relationships>
      <Preferred_Parent>
        <Parent_Subject_ID>300241581</Parent_Subject_ID>
        <Relationship_Type>Parent/Child</Relationship_Type>
        <Historic_Flag>Current</Historic_Flag>
        <Parent_String>components by general context [300241581], components (objects parts) [300241583], Components (hierarchy name) [300241490], Objects Facet [300264092]</Parent_String>
        <Hier_Rel_Type>Genus/Species-BTG</Hier_Rel_Type>
