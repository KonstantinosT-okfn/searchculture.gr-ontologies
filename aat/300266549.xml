    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Small, shallow overcast stitches arranged in a diagonal; used to bind pieces together or to secure small rolled-over hemming.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
