    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>Works of art created as a series, a popular genre since the late 19th century, especially in Minimal art of the 1960s.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
