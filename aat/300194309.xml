    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The symbols 0, 1, 2, and so forth, derived from Arabic numerical notation in the late Middle Ages in Europe.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
