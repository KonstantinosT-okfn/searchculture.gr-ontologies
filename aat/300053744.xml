    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The process of constructing of new objects or structures that are built to replace or resemble earlier ones, based on historic, archaeological, or other similar evidence.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
