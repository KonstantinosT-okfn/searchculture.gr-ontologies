    <Descriptive_Notes>
      <Descriptive_Note>
        <Note_Text>The middle point, especially of a line, circle or sphere, equidistant from the ends or from any point on the circumference or surface.</Note_Text>
        <Note_Language>English</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000000/VP</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
          <Note_Source>
            <Source>
              <Source_ID>2000046352/Oxford English Reference Dictionary (1996)</Source_ID>
            </Source>
          </Note_Source>
        </Note_Sources>
      </Descriptive_Note>
      <Descriptive_Note>
        <Note_Text>El punto medio, sobre todo de una línea, círculo o esfera, equidistante de los extremos o de cualquier punto en la circunferencia o superficie.</Note_Text>
        <Note_Language>Spanish</Note_Language>
        <Note_Contributors>
          <Note_Contributor>
            <Contributor_id>10000131/CDBP-SNPC</Contributor_id>
          </Note_Contributor>
        </Note_Contributors>
        <Note_Sources>
